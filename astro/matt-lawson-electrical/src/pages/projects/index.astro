---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { projects } from '../../data/projects';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title="Recent Projects — Matt Lawson Electrical" description="A look at recent residential, solar, smart-home and commercial work across the Illawarra.">

  <section class="bg-graphite text-bone">
    <div class="wrap-wide py-20 grid md:grid-cols-12 gap-10 items-end">
      <div class="md:col-span-8">
        <p class="eyebrow-light">// Recent work</p>
        <h1 class="text-bone text-5xl md:text-6xl font-bold tracking-tight3">Eight projects<br/>from the last six months.</h1>
        <p class="text-bone/60 text-lg leading-relaxed mt-6 max-w-2xl">A cross-section of jobs we've finished around Wollongong and the Illawarra coast. Residential rewires, Level 2 meter upgrades, solar &amp; battery installs, EV chargers and a full Loxone smart home.</p>
      </div>
      <div class="md:col-span-4 grid grid-cols-3 gap-3 text-center">
        <div class="bg-steel border border-bone/10 rounded-sharp p-4">
          <div class="font-display font-bold text-volt text-3xl">8</div>
          <div class="font-mono uppercase tracking-wide2 text-[10px] text-bone/50 mt-1">Shown</div>
        </div>
        <div class="bg-steel border border-bone/10 rounded-sharp p-4">
          <div class="font-display font-bold text-volt text-3xl">240</div>
          <div class="font-mono uppercase tracking-wide2 text-[10px] text-bone/50 mt-1">This year</div>
        </div>
        <div class="bg-steel border border-bone/10 rounded-sharp p-4">
          <div class="font-display font-bold text-volt text-3xl">2,400+</div>
          <div class="font-mono uppercase tracking-wide2 text-[10px] text-bone/50 mt-1">All time</div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-bone">
    <div class="wrap-wide">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {projects.map(p => <ProjectCard project={p} />)}
      </div>
    </div>
  </section>

  <section class="py-20 bg-graphite text-bone border-t border-bone/10">
    <div class="wrap-wide grid md:grid-cols-12 gap-10 items-center">
      <div class="md:col-span-7">
        <p class="eyebrow-light">// Got one coming up?</p>
        <h2 class="text-bone text-3xl md:text-4xl font-bold tracking-tight3">Every job starts with a phone call and a quote.</h2>
        <p class="text-bone/60 leading-relaxed mt-4 max-w-xl">Whether it's a single switchboard swap or a full architect-designed rebuild, the first step is a conversation. No pressure tactics, no "we'll send a sales rep" nonsense.</p>
      </div>
      <div class="md:col-span-5 flex flex-wrap gap-3 md:justify-end">
        <a href={`${base}/contact/`} class="btn-primary">Get a quote</a>
        <a href="tel:1300528976" class="btn-ghost-light"><span class="font-mono">1300 LAWSON</span></a>
      </div>
    </div>
  </section>

</Base>
