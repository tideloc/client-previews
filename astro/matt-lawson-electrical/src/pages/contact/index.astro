---
import Base from '../../layouts/Base.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title="Contact — Matt Lawson Electrical | Wollongong" description="Phone, email and quote form. Talk to a licensed Wollongong electrician.">

  {/* INTRO */}
  <section class="bg-graphite text-bone">
    <div class="wrap-wide py-20 grid md:grid-cols-12 gap-10 items-end">
      <div class="md:col-span-7">
        <p class="eyebrow-light">// Get in touch</p>
        <h1 class="text-bone text-5xl md:text-6xl font-bold tracking-tight3">Five ways to reach us.<br/>Pick one.</h1>
        <p class="text-bone/60 text-lg leading-relaxed mt-6 max-w-xl">The fastest route is a phone call — 1300 LAWSON is answered by a real person during business hours. For after-hours emergencies, use the direct mobile. For everything else, the form below lands in Matt's inbox within a minute.</p>
      </div>
      <div class="md:col-span-5">
        <div class="bg-steel border border-bone/10 rounded-sharp p-6">
          <div class="flex items-center gap-3 mb-4">
            <span class="dot-live"></span>
            <span class="font-mono uppercase tracking-wide2 text-[11px] text-volt">Office hours · Mon–Sat</span>
          </div>
          <ul class="divide-y divide-bone/10 text-sm">
            <li class="flex items-center justify-between py-2.5"><span class="text-bone/70">Mon – Fri</span><span class="font-mono text-bone">7:00 AM – 5:30 PM</span></li>
            <li class="flex items-center justify-between py-2.5"><span class="text-bone/70">Saturday</span><span class="font-mono text-bone">8:00 AM – 1:00 PM</span></li>
            <li class="flex items-center justify-between py-2.5"><span class="text-bone/70">Sunday</span><span class="font-mono text-bone/50">Emergency only</span></li>
            <li class="flex items-center justify-between py-2.5"><span class="text-volt">24/7 emergency</span><span class="font-mono text-volt">0428 999 413</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  {/* Channels grid */}
  <section class="py-16 bg-bone border-b border-graphite/8">
    <div class="wrap-wide grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {[
        {
          label: 'General enquiries', sub: 'Quotes & bookings',
          big: '1300 LAWSON', sub2: '(1300 528 976)',
          href: 'tel:1300528976',
          icon: '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/>',
        },
        {
          label: '24/7 emergency', sub: 'After-hours direct',
          big: '0428 999 413', sub2: 'Fixed callout fee',
          href: 'tel:0428999413',
          icon: '<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>',
        },
        {
          label: 'Trade & commercial', sub: 'Builders, PM\'s, fitouts',
          big: 'jake@lawson\u200Belectrical.com.au', sub2: 'POA quoting',
          href: 'mailto:jake@lawsonelectrical.com.au',
          icon: '<path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/><polyline points="22 6 12 13 2 6"/>',
        },
        {
          label: 'Visit the workshop', sub: 'By appointment',
          big: 'Unit 3 / 142 Auburn St', sub2: 'Wollongong NSW 2500',
          href: 'https://maps.google.com/?q=Auburn+St+Wollongong',
          icon: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
        },
      ].map(c => (
        <a href={c.href} class="group card flex flex-col p-6 h-full">
          <div class="w-10 h-10 bg-graphite text-volt rounded-sharp flex items-center justify-center mb-4 transition group-hover:bg-volt group-hover:text-graphite">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={c.icon}/>
          </div>
          <div class="font-mono uppercase tracking-wide2 text-[11px] text-charge">{c.label}</div>
          <div class="text-dust text-[12px] mb-3">{c.sub}</div>
          <div class="font-display font-bold text-graphite text-[18px] leading-snug tracking-tight2">{c.big}</div>
          <div class="text-dust text-[13px] mt-1">{c.sub2}</div>
        </a>
      ))}
    </div>
  </section>

  {/* Quote form */}
  <section class="py-20 bg-bone">
    <div class="wrap-wide grid md:grid-cols-12 gap-10">
      <div class="md:col-span-5">
        <p class="eyebrow">// Quote request</p>
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight3">Tell us what you need. We'll come back the same day.</h2>
        <p class="text-dust leading-relaxed mt-5">The more detail (and photos) you include, the more accurate the first quote we send back. For anything bigger than a single circuit we'll usually book a site visit before confirming the fixed price.</p>
        <ul class="mt-8 space-y-3">
          {[
            'Response inside 60 min during business hours',
            'Fixed-price quote within 24 hours of site visit',
            'No call-out or quoting fee',
            'Photos & videos welcome',
          ].map(x => (
            <li class="flex items-start gap-3 text-graphite">
              <span class="w-6 h-6 bg-volt text-graphite rounded-sharp flex items-center justify-center shrink-0 mt-0.5">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="font-display text-[15px]">{x}</span>
            </li>
          ))}
        </ul>
      </div>
      <form
        class="md:col-span-7 bg-chalk border border-graphite/10 rounded-sharp p-8 grid sm:grid-cols-2 gap-4"
        onsubmit="event.preventDefault(); this.innerHTML = '<div class=&quot;col-span-full text-center py-10&quot;><div class=&quot;w-14 h-14 bg-volt text-graphite rounded-sharp flex items-center justify-center mx-auto mb-4&quot;><svg width=&quot;26&quot; height=&quot;26&quot; viewBox=&quot;0 0 24 24&quot; fill=&quot;none&quot; stroke=&quot;currentColor&quot; stroke-width=&quot;2.6&quot; stroke-linecap=&quot;round&quot; stroke-linejoin=&quot;round&quot;><polyline points=&quot;20 6 9 17 4 12&quot;/></svg></div><div class=&quot;font-display text-2xl font-bold&quot;>Thanks — we\'re on it.</div><p class=&quot;text-dust mt-2&quot;>We\'ll come back to you during business hours. For urgent jobs call <a class=&quot;text-charge font-semibold&quot; href=&quot;tel:1300528976&quot;>1300 LAWSON</a>.</p></div>';"
      >
        <label class="flex flex-col gap-1.5">
          <span class="font-mono uppercase tracking-wide2 text-[11px] text-dust">Full name *</span>
          <input required class="bg-bone border border-graphite/15 rounded-sharp px-4 py-3 text-graphite placeholder:text-dust/60 font-body focus:border-volt outline-none" placeholder="e.g. Sarah Thompson"/>
        </label>
        <label class="flex flex-col gap-1.5">
          <span class="font-mono uppercase tracking-wide2 text-[11px] text-dust">Phone *</span>
          <input required type="tel" class="bg-bone border border-graphite/15 rounded-sharp px-4 py-3 text-graphite placeholder:text-dust/60 font-mono focus:border-volt outline-none" placeholder="04xx xxx xxx"/>
        </label>
        <label class="flex flex-col gap-1.5">
          <span class="font-mono uppercase tracking-wide2 text-[11px] text-dust">Email</span>
          <input type="email" class="bg-bone border border-graphite/15 rounded-sharp px-4 py-3 text-graphite placeholder:text-dust/60 font-body focus:border-volt outline-none" placeholder="you@email.com"/>
        </label>
        <label class="flex flex-col gap-1.5">
          <span class="font-mono uppercase tracking-wide2 text-[11px] text-dust">Suburb *</span>
          <input required class="bg-bone border border-graphite/15 rounded-sharp px-4 py-3 text-graphite placeholder:text-dust/60 font-body focus:border-volt outline-none" placeholder="e.g. Figtree"/>
        </label>
        <label class="flex flex-col gap-1.5 sm:col-span-2">
          <span class="font-mono uppercase tracking-wide2 text-[11px] text-dust">Job type</span>
          <select class="bg-bone border border-graphite/15 rounded-sharp px-4 py-3 text-graphite font-body focus:border-volt outline-none">
            <option>Residential wiring / rewire</option>
            <option>Switchboard upgrade</option>
            <option>Safety switches &amp; smoke alarms</option>
            <option>Solar installation</option>
            <option>EV charger installation</option>
            <option>Smart home automation</option>
            <option>LED lighting retrofit</option>
            <option>Commercial fitout</option>
            <option>Level 2 meter / service mains</option>
            <option>Emergency (call us instead)</option>
          </select>
        </label>
        <label class="flex flex-col gap-1.5 sm:col-span-2">
          <span class="font-mono uppercase tracking-wide2 text-[11px] text-dust">Tell us about the job *</span>
          <textarea required rows="5" class="bg-bone border border-graphite/15 rounded-sharp px-4 py-3 text-graphite placeholder:text-dust/60 font-body focus:border-volt outline-none resize-y" placeholder="A sentence or two on what needs doing. Photos welcome — feel free to text them once we confirm."></textarea>
        </label>
        <button class="btn-primary sm:col-span-2 !py-3.5">Send quote request</button>
        <p class="sm:col-span-2 text-center text-[11px] font-mono uppercase tracking-wide2 text-dust">Replies within 60 min during business hours · EC12345</p>
      </form>
    </div>
  </section>

  {/* Map strip */}
  <section class="bg-graphite border-t border-bone/10">
    <div class="wrap-wide py-16 grid md:grid-cols-12 gap-10 items-center">
      <div class="md:col-span-5 text-bone">
        <p class="eyebrow-light">// Find us</p>
        <h2 class="text-bone text-3xl md:text-4xl font-bold tracking-tight3">Workshop on Auburn St.</h2>
        <p class="text-bone/60 leading-relaxed mt-4">By appointment only — the team is usually on site, but drop a message and we'll carve out a time. Parking in the rear lane.</p>
        <p class="text-bone/80 mt-6 leading-relaxed">
          Unit 3 / 142 Auburn St<br/>
          Wollongong NSW 2500
        </p>
      </div>
      <div class="md:col-span-7 rounded-sharp overflow-hidden border border-bone/10 aspect-[4/3] bg-steel">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d13263.44!2d150.893!3d-34.423!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s!2sWollongong%20NSW!5e0!3m2!1sen!2sau"
          class="w-full h-full border-0"
          allowfullscreen="true"
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>
    </div>
  </section>

</Base>
