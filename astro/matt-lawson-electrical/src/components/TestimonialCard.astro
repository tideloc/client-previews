---
import type { Testimonial } from '../data/testimonials';

interface Props {
  testimonial: Testimonial;
  variant?: 'light' | 'dark';
}
const { testimonial, variant = 'light' } = Astro.props;
const isDark = variant === 'dark';
const stars = Array.from({ length: 5 }, (_, i) => i < testimonial.rating);
---
<figure class={`rounded-sharp p-6 border flex flex-col gap-4 ${isDark ? 'bg-steel border-bone/10 text-bone' : 'bg-chalk border-graphite/10'}`}>
  <div class={`flex items-center gap-1 text-[12px] ${isDark ? 'text-volt' : 'text-charge'}`}>
    {stars.map((filled) => (
      <svg width="14" height="14" viewBox="0 0 24 24" fill={filled ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="1.6" stroke-linejoin="round">
        <polygon points="12 2 15 8.5 22 9.3 17 14 18.3 21 12 17.6 5.7 21 7 14 2 9.3 9 8.5 12 2" />
      </svg>
    ))}
    <span class={`ml-2 font-mono uppercase tracking-wide2 text-[10px] ${isDark ? 'text-bone/40' : 'text-dust'}`}>{testimonial.jobType}</span>
  </div>
  <blockquote class={`font-display text-[17px] leading-snug tracking-tight2 ${isDark ? 'text-bone/90' : 'text-graphite'}`}>
    "{testimonial.quote}"
  </blockquote>
  <figcaption class={`flex items-center gap-3 mt-auto pt-3 border-t ${isDark ? 'border-bone/10' : 'border-graphite/8'}`}>
    <img
      src={testimonial.image}
      alt={testimonial.name}
      width="40"
      height="40"
      class="w-10 h-10 rounded-full object-cover shrink-0"
    />
    <div>
      <div class={`font-display font-semibold text-[13px] ${isDark ? 'text-bone' : 'text-graphite'}`}>{testimonial.name}</div>
      <div class={`font-mono uppercase tracking-wide2 text-[10px] ${isDark ? 'text-bone/40' : 'text-dust'}`}>{testimonial.suburb}</div>
    </div>
  </figcaption>
</figure>
