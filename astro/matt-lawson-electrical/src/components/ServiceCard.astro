---
import type { Service } from '../data/services';

interface Props {
  service: Service;
  compact?: boolean;
}
const { service, compact = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Simple stroke icons to match the "trades meets SaaS" aesthetic
const ICONS: Record<string, string> = {
  home:   '<path d="M3 12l9-9 9 9"/><path d="M5 10v10h14V10"/><path d="M10 20v-6h4v6"/>',
  board:  '<rect x="4" y="3" width="16" height="18" rx="1"/><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/>',
  alarm:  '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3"/><path d="M3 3l2 2"/><path d="M19 3l2 2"/>',
  bolt:   '<path d="M13 2 4 14h7l-1 8 9-12h-7l1-8z"/>',
  sun:    '<circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="M4.93 4.93l1.41 1.41"/><path d="M17.66 17.66l1.41 1.41"/><path d="M4.93 19.07l1.41-1.41"/><path d="M17.66 6.34l1.41-1.41"/>',
  plug:   '<path d="M9 2v6"/><path d="M15 2v6"/><path d="M18 8H6v4a6 6 0 0 0 6 6 6 6 0 0 0 6-6z"/><path d="M12 18v4"/>',
  chip:   '<rect x="5" y="5" width="14" height="14" rx="1"/><path d="M9 5V2"/><path d="M15 5V2"/><path d="M9 22v-3"/><path d="M15 22v-3"/><path d="M2 9h3"/><path d="M2 15h3"/><path d="M19 9h3"/><path d="M19 15h3"/>',
  bulb:   '<path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 0-4 12c1 1 2 2 2 4h4c0-2 1-3 2-4a7 7 0 0 0-4-12z"/>',
  office: '<rect x="3" y="3" width="18" height="18" rx="1"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="15" y1="3" x2="15" y2="21"/>',
  tower:  '<path d="M12 2v20"/><path d="M8 4l4-2 4 2"/><path d="M7 9l5-2 5 2"/><path d="M6 14l6-2 6 2"/>',
};
const iconPaths = ICONS[service.icon] ?? ICONS.bolt;

const categoryLabels: Record<string, string> = {
  residential: 'Residential',
  emergency: 'Emergency',
  solar: 'Solar & EV',
  smart: 'Smart Home',
  commercial: 'Commercial',
  level2: 'Level 2',
};
---
<a
  href={`${base}/services/${service.slug}/`}
  class="group card flex flex-col h-full"
>
  {!compact && (
    <div class="aspect-[16/10] overflow-hidden bg-bone">
      <img
        src={service.image}
        alt={service.name}
        class="w-full h-full object-cover transition duration-500 group-hover:scale-[1.03]"
      />
    </div>
  )}
  <div class="p-6 flex flex-col gap-3 flex-1">
    <div class="flex items-center justify-between">
      <span class="w-10 h-10 bg-graphite text-volt rounded-sharp flex items-center justify-center transition group-hover:bg-volt group-hover:text-graphite">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths} />
      </span>
      <span class="font-mono uppercase tracking-wide2 text-[10px] text-dust">{categoryLabels[service.category]}</span>
    </div>

    <h3 class="font-display font-bold text-graphite text-[17px] leading-snug tracking-tight2">{service.name}</h3>
    <p class="text-dust text-sm leading-relaxed flex-1">{service.blurb}</p>

    <div class="mt-2 pt-4 border-t border-graphite/8 flex items-center justify-between text-[12px]">
      <div>
        <div class="font-mono uppercase tracking-wide2 text-[10px] text-dust">From</div>
        <div class="font-display font-semibold text-graphite">{service.startingPrice}</div>
      </div>
      <span class="font-display text-[13px] font-semibold text-graphite transition group-hover:text-charge">
        Details →
      </span>
    </div>
  </div>
</a>
