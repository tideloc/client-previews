---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const links = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/services/`, label: 'Services' },
  { href: `${base}/projects/`, label: 'Projects' },
  { href: `${base}/about/`, label: 'About' },
  { href: `${base}/service-area/`, label: 'Service Area' },
  { href: `${base}/contact/`, label: 'Contact' },
];
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="sticky top-0 z-40 bg-chalk/92 backdrop-blur-md border-b border-graphite/10">
  <div class="bg-graphite text-bone/80 text-[11px]">
    <div class="wrap-wide py-2 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="dot-live"></span>
        <span class="font-mono uppercase tracking-wide2 hidden sm:inline">NSW Lic. EC12345 · Fully insured</span>
        <span class="font-mono uppercase tracking-wide2 sm:hidden">Lic. EC12345</span>
      </div>
      <div class="hidden md:flex items-center gap-4 text-bone/60 font-mono uppercase tracking-wide2">
        <span>Wollongong &amp; Illawarra</span>
        <span class="text-bone/25">·</span>
        <a href="mailto:matt@lawsonelectrical.com.au" class="hover:text-volt">matt@lawsonelectrical.com.au</a>
      </div>
    </div>
  </div>
  <div class="wrap-wide flex items-center justify-between py-4">
    <a href={`${base}/`} class="flex items-center gap-3 group">
      <span class="relative w-10 h-10 bg-graphite text-volt flex items-center justify-center font-display font-bold text-lg rounded-sharp transition group-hover:bg-volt group-hover:text-graphite">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 4 14h7l-1 8 9-12h-7l1-8z"/></svg>
      </span>
      <div class="leading-tight">
        <div class="font-display font-bold text-graphite text-[15px] tracking-tight2">Matt Lawson Electrical</div>
        <div class="font-mono text-[10px] text-dust uppercase tracking-wide1">Wollongong · Lic. EC12345</div>
      </div>
    </a>
    <nav class="hidden lg:flex items-center gap-1">
      {links.map(l => {
        const href = l.href.replace(/\/$/, '') || '/';
        const isActive = pathname === href || (l.href === `${base}/` && (pathname === base || pathname === '/'));
        return (
          <a
            href={l.href}
            class={`font-display font-medium text-[13px] px-3 py-2 rounded-sharp transition hover:text-graphite ${isActive ? 'text-graphite' : 'text-dust'}`}
          >
            {l.label}
          </a>
        );
      })}
      <a href="tel:1300528976" class="btn-primary ml-3 !py-2 !px-4 !text-[13px] gap-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
        <span class="font-mono">1300 LAWSON</span>
      </a>
    </nav>
    <button id="menuToggle" class="lg:hidden text-graphite p-2" aria-label="Menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="4" y1="7" x2="20" y2="7" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="17" x2="20" y2="17" />
      </svg>
    </button>
  </div>
  <div id="mobileMenu" class="hidden lg:hidden border-t border-graphite/10 bg-chalk">
    <div class="wrap-wide py-4 flex flex-col gap-1">
      {links.map(l => (
        <a href={l.href} class="font-display font-medium text-sm text-graphite py-2 hover:text-charge">{l.label}</a>
      ))}
      <a href="tel:1300528976" class="btn-primary mt-3 !py-2.5 !text-sm">Call 1300 LAWSON</a>
    </div>
  </div>
</header>
<script>
  const btn = document.getElementById('menuToggle');
  const menu = document.getElementById('mobileMenu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
