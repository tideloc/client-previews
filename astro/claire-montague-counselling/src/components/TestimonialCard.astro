---
import type { Testimonial } from '../data/testimonials';
interface Props {
  testimonial: Testimonial;
}
const { testimonial } = Astro.props;
---
<figure class="card-soft p-8 md:p-10">
  <div class="font-display text-4xl text-sage leading-none mb-4">&ldquo;</div>
  <blockquote class="font-display text-ink text-[22px] md:text-[24px] leading-[1.5] mb-6" style="font-weight:400;">
    {testimonial.quote}
  </blockquote>
  <figcaption class="font-mono text-[11px] uppercase text-slate tracking-[0.18em]">
    — {testimonial.credit}
  </figcaption>
</figure>
