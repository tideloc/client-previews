---
import Base from '../../layouts/Base.astro';
import { topics } from '../../data/topics';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title="What I help with — Claire Montague Counselling">
  <section class="pt-16 md:pt-24 pb-12">
    <div class="wrap-wide max-w-3xl">
      <p class="eyebrow">What I help with</p>
      <h1 class="font-display text-ink text-[clamp(2.5rem,6vw,4.5rem)] mb-8">
        Six territories <em style="font-style:italic;font-weight:400;">I sit with often.</em>
      </h1>
      <p class="text-slate text-[18px] leading-loose">
        Most people arrive with some combination of these — rarely a single clean thread. Read the one that feels nearest. You do not have to know, in advance, which drawer you belong in.
      </p>
    </div>
  </section>

  <section class="pb-8">
    <div class="wrap-wide">
      <div class="flex flex-wrap gap-2">
        {topics.map(t => (
          <a href={`#${t.slug}`} class="font-mono text-[11px] uppercase text-slate tracking-[0.18em] px-4 py-2 border border-ink/15 rounded-sm hover:border-sage hover:text-deepsage transition">
            {t.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  {topics.map((t, i) => (
    <section id={t.slug} class={`py-20 md:py-24 ${i % 2 === 1 ? 'bg-cream' : ''}`}>
      <div class="wrap-wide grid md:grid-cols-12 gap-10 md:gap-14 items-start">
        <div class={`md:col-span-5 ${i % 2 === 1 ? 'md:order-2' : ''}`}>
          <img src={t.image} alt="" class="w-full aspect-[4/5] object-cover rounded-sm" />
        </div>
        <div class={`md:col-span-7 ${i % 2 === 1 ? 'md:order-1' : ''}`}>
          <p class="eyebrow">0{i + 1} · {t.shortBlurb}</p>
          <h2 class="font-display text-ink text-4xl md:text-5xl mb-8">{t.name}</h2>
          <div class="prose-reading">
            <p>{t.longBlurb}</p>
          </div>

          <div class="mt-10 grid sm:grid-cols-2 gap-6">
            <div>
              <p class="font-mono text-[11px] uppercase text-sage tracking-[0.18em] mb-3">You might recognise</p>
              <ul class="space-y-2 text-slate text-[15px] leading-loose list-none p-0 m-0">
                {t.commonSigns.map(s => (
                  <li class="pl-5 relative">
                    <span class="absolute left-0 top-[0.8em] w-2 h-px bg-sage"></span>
                    {s}
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <p class="font-mono text-[11px] uppercase text-sage tracking-[0.18em] mb-3">How I work with this</p>
              <p class="text-slate text-[15px] leading-loose">{t.approach}</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  <section class="py-24 md:py-28">
    <div class="wrap-narrow text-center">
      <h2 class="font-display text-ink text-4xl md:text-5xl mb-6">
        None of these fit, <em style="font-style:italic;font-weight:400;">exactly?</em>
      </h2>
      <p class="text-slate text-[17px] leading-loose mb-10">
        That is common and fine. These are the territories I know best, not the only ones I work in. Let's talk on a free intro call — I'll tell you honestly if I'm the right fit, and if not I'll usually know someone who is.
      </p>
      <a href={`${base}/contact/`} class="btn-primary">Book an intro call</a>
    </div>
  </section>
</Base>
