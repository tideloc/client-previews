---
import Base from '../../layouts/Base.astro';
import { journal } from '../../data/journal';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title="Journal — Claire Montague Counselling">
  <section class="pt-16 md:pt-24 pb-12">
    <div class="wrap-wide max-w-3xl">
      <p class="eyebrow">Journal</p>
      <h1 class="font-display text-ink text-[clamp(2.5rem,6vw,4.5rem)] mb-8">
        Short essays <em style="font-style:italic;font-weight:400;">on the quieter work.</em>
      </h1>
      <p class="text-slate text-[18px] leading-loose">
        I write occasionally on the territories I sit with most often — burnout, grief, nervous systems, late diagnosis, the strange honest work of therapy. Not advice. More like thinking alongside.
      </p>
    </div>
  </section>

  {journal.map((e, i) => {
    const date = new Date(e.date).toLocaleDateString('en-AU', { day: 'numeric', month: 'long', year: 'numeric' });
    const paragraphs = e.body.split('\n\n');
    return (
      <article id={e.slug} class={`py-16 md:py-20 ${i % 2 === 1 ? 'bg-cream' : ''}`}>
        <div class="wrap-wide grid md:grid-cols-12 gap-10 md:gap-14 items-start">
          <div class={`md:col-span-5 ${i % 2 === 1 ? 'md:order-2' : ''}`}>
            <img src={e.image} alt="" class="w-full aspect-[4/5] object-cover rounded-sm" />
            <div class="mt-5 flex items-center gap-3">
              <span class="font-mono text-[11px] uppercase text-sage tracking-[0.18em]">{date}</span>
              <span class="w-1 h-1 rounded-full bg-slate/40"></span>
              <span class="font-mono text-[11px] uppercase text-slate/70 tracking-[0.18em]">{e.readTime}</span>
            </div>
          </div>
          <div class={`md:col-span-7 ${i % 2 === 1 ? 'md:order-1' : ''}`}>
            <p class="font-mono text-[11px] uppercase text-sage tracking-[0.18em] mb-4">Essay 0{i + 1}</p>
            <h2 class="font-display text-ink text-4xl md:text-5xl mb-6">
              {e.title}
            </h2>
            <div class="prose-reading">
              {paragraphs.map(p => <p>{p}</p>)}
            </div>
          </div>
        </div>
      </article>
    );
  })}

  <section class="py-24 md:py-28">
    <div class="wrap-narrow text-center">
      <h2 class="font-display text-ink text-4xl md:text-5xl mb-6">
        If any of this <em style="font-style:italic;font-weight:400;">landed —</em>
      </h2>
      <p class="text-slate text-[17px] leading-loose mb-10">
        An intro call is the friendliest way to start. Twenty minutes, free, no paperwork.
      </p>
      <a href={`${base}/contact/`} class="btn-primary">Book an intro call</a>
    </div>
  </section>
</Base>
