---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const links = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/shop/`, label: 'Shop' },
  { href: `${base}/recipes/`, label: 'Recipes' },
  { href: `${base}/about/`, label: 'Our Story' },
  { href: `${base}/stockists/`, label: 'Stockists' },
];
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="sticky top-0 z-40 bg-ink/90 backdrop-blur-md border-b border-ember/20">
  <div class="wrap flex items-center justify-between py-4">
    <a href={`${base}/`} class="flex items-center gap-3 group">
      <span class="w-10 h-10 bg-ember text-ink flex items-center justify-center font-display text-lg rounded-sm transition group-hover:rotate-3 group-hover:bg-flame">BB</span>
      <div class="leading-tight">
        <div class="font-display uppercase text-bone tracking-shout text-sm">Blaze Brothers</div>
        <div class="font-mono text-[10px] text-ember uppercase">Est. Brisbane</div>
      </div>
    </a>
    <nav class="hidden md:flex items-center gap-1">
      {links.map(l => {
        const isActive = pathname === l.href.replace(/\/$/, '') || (l.href === `${base}/` && pathname === base);
        return (
          <a
            href={l.href}
            class={`font-display uppercase tracking-shout text-xs px-4 py-2 rounded-sm transition hover:text-ember ${isActive ? 'text-ember' : 'text-bone/80'}`}
          >
            {l.label}
          </a>
        );
      })}
      <a href={`${base}/shop/`} class="btn-primary ml-3 !py-2 !px-4 !text-xs">Get Sauce</a>
    </nav>
    <button id="menuToggle" class="md:hidden text-bone p-2" aria-label="Menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="4" y1="7" x2="20" y2="7" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="17" x2="20" y2="17" />
      </svg>
    </button>
  </div>
  <div id="mobileMenu" class="hidden md:hidden border-t border-ember/20 bg-ink">
    <div class="wrap py-4 flex flex-col gap-1">
      {links.map(l => (
        <a href={l.href} class="font-display uppercase tracking-shout text-sm text-bone py-2 hover:text-ember">{l.label}</a>
      ))}
    </div>
  </div>
</header>
<script>
  const btn = document.getElementById('menuToggle');
  const menu = document.getElementById('mobileMenu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
