---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();
---
<footer class="mt-24 border-t border-ember/20 bg-ink">
  <div class="wrap py-16 grid md:grid-cols-4 gap-10">
    <div>
      <div class="flex items-center gap-3 mb-4">
        <span class="w-10 h-10 bg-ember text-ink flex items-center justify-center font-display text-lg rounded-sm">BB</span>
        <div class="font-display uppercase text-bone tracking-shout text-sm">Blaze Brothers</div>
      </div>
      <p class="text-dust text-sm leading-relaxed">Small-batch artisan hot sauces, BBQ rubs and spice blends. Cooked slow, bottled hot, shipped from Brisbane.</p>
    </div>
    <div>
      <h4 class="text-bone text-xs mb-4">Shop</h4>
      <ul class="space-y-2 text-sm">
        <li><a href={`${base}/shop/#sauces`} class="text-dust hover:text-ember">All Sauces</a></li>
        <li><a href={`${base}/shop/#rubs`} class="text-dust hover:text-ember">BBQ Rubs</a></li>
        <li><a href={`${base}/shop/#packs`} class="text-dust hover:text-ember">Gift Packs</a></li>
        <li><a href={`${base}/recipes/`} class="text-dust hover:text-ember">Recipes</a></li>
      </ul>
    </div>
    <div>
      <h4 class="text-bone text-xs mb-4">Company</h4>
      <ul class="space-y-2 text-sm">
        <li><a href={`${base}/about/`} class="text-dust hover:text-ember">Our Story</a></li>
        <li><a href={`${base}/stockists/`} class="text-dust hover:text-ember">Stockists</a></li>
        <li><a href={`${base}/stockists/#wholesale`} class="text-dust hover:text-ember">Wholesale</a></li>
        <li><a href={`${base}/stockists/#contact`} class="text-dust hover:text-ember">Contact</a></li>
      </ul>
    </div>
    <div>
      <h4 class="text-bone text-xs mb-4">Find Us</h4>
      <address class="not-italic text-sm text-dust leading-relaxed">
        Blaze Bros. HQ<br/>
        Unit 4 / 88 Montague Rd<br/>
        South Brisbane QLD 4101<br/>
        <a href="mailto:fire@blazebros.com.au" class="text-ember hover:text-flame">fire@blazebros.com.au</a>
      </address>
    </div>
  </div>
  <div class="border-t border-ember/10">
    <div class="wrap py-6 flex flex-col md:flex-row items-center justify-between gap-2 text-xs text-dust">
      <span>© {year} Blaze Brothers Hot Sauce Co. All rights reserved.</span>
      <span class="font-mono uppercase">Brewed in Brisbane · Shipped Australia-wide</span>
    </div>
  </div>
</footer>
