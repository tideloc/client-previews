---
import Base from '../../layouts/Base.astro';
import HeatScale from '../../components/HeatScale.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products } from '../../data/products';

export function getStaticPaths() {
  return products.map(p => ({ params: { slug: p.slug }, props: { product: p } }));
}

const { product } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const related = products.filter(p => p.slug !== product.slug && p.category === product.category).slice(0, 3);
const backup = products.filter(p => p.slug !== product.slug).slice(0, 3);
const show = related.length >= 2 ? related : backup;
---
<Base title={`${product.name} — Blaze Brothers`} description={product.tagline}>
  <section class="pt-12 pb-20">
    <div class="wrap">
      <nav class="text-xs font-mono uppercase tracking-wide text-dust mb-10">
        <a href={`${base}/shop/`} class="hover:text-ember">Shop</a>
        <span class="mx-2 text-bone/30">/</span>
        <span class="text-bone/60">{product.category}</span>
        <span class="mx-2 text-bone/30">/</span>
        <span class="text-ember">{product.name}</span>
      </nav>

      <div class="grid md:grid-cols-2 gap-14">
        <div class="relative bg-ash rounded-sm overflow-hidden">
          <img src={product.image} alt={product.name} class="w-full aspect-[4/5] object-cover" />
          {product.badge && (
            <span class="absolute top-5 left-5 bg-ember text-ink px-3 py-1 font-display uppercase tracking-shout text-xs">{product.badge}</span>
          )}
        </div>
        <div>
          <p class="eyebrow">{product.category}</p>
          <h1 class="text-5xl md:text-6xl text-bone leading-none mb-4">{product.name}</h1>
          <p class="text-ember text-xl font-display uppercase tracking-shout mb-6">{product.tagline}</p>

          <div class="flex items-center gap-8 mb-10 py-5 border-y border-ember/20">
            <div>
              <div class="text-[10px] font-mono uppercase tracking-shout text-dust">Price</div>
              <div class="text-3xl text-bone font-display">${product.price}</div>
            </div>
            <div>
              <div class="text-[10px] font-mono uppercase tracking-shout text-dust">Size</div>
              <div class="text-bone font-display text-lg">{product.size}</div>
            </div>
            <div>
              <div class="text-[10px] font-mono uppercase tracking-shout text-dust mb-2">Heat</div>
              <HeatScale level={product.heat} />
            </div>
          </div>

          <p class="text-bone/80 text-lg leading-relaxed mb-8">{product.description}</p>

          <div class="flex items-center gap-4 mb-12">
            <div class="flex items-center border border-bone/20 rounded-sm">
              <button class="w-10 h-12 text-bone hover:text-ember" aria-label="Decrease quantity">−</button>
              <span class="w-12 text-center font-display text-lg text-bone">1</span>
              <button class="w-10 h-12 text-bone hover:text-ember" aria-label="Increase quantity">+</button>
            </div>
            <button class="btn-primary flex-1">Add to cart · ${product.price}</button>
          </div>

          <dl class="space-y-6 text-sm">
            <div>
              <dt class="font-display uppercase tracking-shout text-ember text-xs mb-2">Pair with</dt>
              <dd class="text-bone/80">{product.pairs.join(' · ')}</dd>
            </div>
            <div>
              <dt class="font-display uppercase tracking-shout text-ember text-xs mb-2">Ingredients</dt>
              <dd class="text-bone/80">{product.ingredients.join(', ')}.</dd>
            </div>
            <div>
              <dt class="font-display uppercase tracking-shout text-ember text-xs mb-2">Made</dt>
              <dd class="text-bone/80">Hand-bottled at our South Brisbane kitchen. Unpasteurised, no gums, no colours. Refrigerate after opening. Gluten-free &amp; vegan.</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  {show.length > 0 && (
    <section class="py-20 bg-ink">
      <div class="wrap">
        <div class="flex items-end justify-between mb-10">
          <h2 class="text-3xl md:text-4xl text-bone">You might also burn</h2>
          <a href={`${base}/shop/`} class="text-ember font-display uppercase tracking-shout text-sm hover:text-flame">Back to shop →</a>
        </div>
        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
          {show.map(p => <ProductCard product={p} />)}
        </div>
      </div>
    </section>
  )}
</Base>
