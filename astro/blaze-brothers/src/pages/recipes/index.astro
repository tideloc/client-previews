---
import Base from '../../layouts/Base.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { recipes } from '../../data/recipes';

const byCat = {
  chicken: recipes.filter(r => r.category === 'chicken'),
  beef: recipes.filter(r => r.category === 'beef'),
  pork: recipes.filter(r => r.category === 'pork'),
  seafood: recipes.filter(r => r.category === 'seafood'),
  veg: recipes.filter(r => r.category === 'veg'),
};
const hero = recipes[0];
const heroImg = 'https://images.unsplash.com/photo-1555939594-58d7cb561ad1?w=2000&h=1100&fit=crop&q=80&auto=format';
---
<Base title="Recipes — Blaze Brothers" description="Hot sauce recipes, BBQ cooks and weeknight heat from the Blaze brothers' South Brisbane kitchen.">
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img src={heroImg} alt="" class="w-full h-full object-cover opacity-45" />
      <div class="absolute inset-0 bg-gradient-to-b from-ink/70 to-smoke"></div>
    </div>
    <div class="wrap relative py-20 md:py-32">
      <p class="eyebrow">Recipes</p>
      <h1 class="text-5xl md:text-8xl text-bone leading-none">Cook like<br/><span class="text-ember">a Blaze.</span></h1>
      <p class="text-bone/80 text-lg md:text-xl max-w-2xl mt-8">
        Recipes from our Sunday cook-ups — the ones that pair properly with each bottle. No fussy garnishes. Big flavour. Tested in our backyard until the smoker runs out of wood.
      </p>
    </div>
  </section>

  {/* Category filters */}
  <nav class="border-y border-ember/20 bg-ink sticky top-[72px] z-30" aria-label="Recipe categories">
    <div class="wrap flex flex-wrap gap-1 py-3">
      <a href="#all" class="font-display uppercase tracking-shout text-xs px-4 py-2 rounded-sm bg-ember text-ink">All ({recipes.length})</a>
      {Object.entries(byCat).map(([cat, list]) => (
        <a href={`#${cat}`} class="font-display uppercase tracking-shout text-xs px-4 py-2 rounded-sm text-bone/70 hover:text-ember">
          {cat} ({list.length})
        </a>
      ))}
    </div>
  </nav>

  {/* All recipes grid */}
  <section id="all" class="py-16 scroll-mt-48">
    <div class="wrap">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {recipes.map(r => <RecipeCard recipe={r} />)}
      </div>
    </div>
  </section>

  {/* Pro tip band */}
  <section class="py-20 bg-ink border-t border-ember/20">
    <div class="wrap max-w-3xl">
      <p class="eyebrow">House rule</p>
      <h2 class="text-3xl md:text-5xl text-bone mb-5">Always start under the heat you think you can handle.</h2>
      <p class="text-bone/80 text-lg leading-relaxed">
        You can always add more sauce. You can't take it out. Every Blaze bottle carries the heat scale on the label — check before you pour, especially with Sunset Reaper. We've been wrong about our own tolerance before; it never ended well.
      </p>
    </div>
  </section>
</Base>
