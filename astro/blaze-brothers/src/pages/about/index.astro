---
import Base from '../../layouts/Base.astro';

const brothersImg = 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=1800&h=1200&fit=crop&q=80&auto=format';
const kitchenImg = 'https://images.unsplash.com/photo-1577303935007-0d306ee638cf?w=1200&h=900&fit=crop&q=80&auto=format';
const marketImg = 'https://images.unsplash.com/photo-1542838132-92c53300491e?w=1200&h=900&fit=crop&q=80&auto=format';
const warehouseImg = 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=1200&h=900&fit=crop&q=80&auto=format';
const flameImg = 'https://images.unsplash.com/photo-1530533718754-001d2668365a?w=2000&h=900&fit=crop&q=80&auto=format';

const timeline = [
  { year: '2016', text: 'Dan blows his head off with a mystery chilli at a night market in Chiang Mai. Becomes obsessed.' },
  { year: '2017', text: 'Mick quits the Sunday roast rotation and starts smoking briskets in Dan\'s Paddington backyard.' },
  { year: '2019', text: 'First 20 bottles of Widowmaker sell out at Jan Powers Farmers Market in 90 minutes.' },
  { year: '2021', text: 'Move into a dedicated commercial kitchen in South Brisbane. Hire a bottling machine they name "Clive".' },
  { year: '2023', text: 'Win gold at the Royal Queensland Food & Wine Show for Bush Smoulder. Cry a little.' },
  { year: '2025', text: '45+ stockists across QLD and NSW. Two brothers, one smoker, thousands of bottles a month.' },
];
---
<Base title="Our Story — Blaze Brothers" description="The story of Dan and Mick Blaze — South Brisbane, a tin shed, one very small smoker, and a lot of chillies.">
  {/* Hero */}
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img src={brothersImg} alt="" class="w-full h-full object-cover opacity-50" />
      <div class="absolute inset-0 bg-gradient-to-b from-ink/70 to-smoke"></div>
    </div>
    <div class="wrap relative py-20 md:py-32">
      <p class="eyebrow">Our Story</p>
      <h1 class="text-5xl md:text-8xl text-bone leading-none">Two brothers.<br/><span class="text-ember">One tin shed.</span></h1>
    </div>
  </section>

  {/* Opening paragraph block */}
  <section class="py-24">
    <div class="wrap grid md:grid-cols-12 gap-10">
      <div class="md:col-span-7">
        <p class="eyebrow">How it started</p>
        <h2 class="text-4xl md:text-5xl text-bone mb-8">A chilli in Thailand. A smoker in Paddington. The rest is noise.</h2>
        <div class="space-y-5 text-bone/80 text-lg leading-relaxed">
          <p>Dan Blaze ate a chilli he couldn't name at a night market in Chiang Mai in 2016. It took him forty-five minutes to recover, and about two years to admit it was the best thing he'd ever eaten.</p>
          <p>Mick Blaze — Dan's younger, louder, more-patient brother — was already smoking briskets in his Paddington backyard every other Sunday, using a smoker they'd welded together from an old 44-gallon drum and half a weber kettle.</p>
          <p>In early 2019 the brothers pooled their obsessions. Mick brought the smoke. Dan brought the heat. They made twenty bottles in a week, labelled them with a sharpie, and took them to the Jan Powers markets. They didn't go home with any bottles.</p>
          <p>Six years on, they've got a commercial kitchen, a proper smoker, and a lot more bottles. But every Saturday at sparrow's, one of them is still hand-labelling, and one of them is still behind the market trestle. They kind of like it that way.</p>
        </div>
      </div>
      <div class="md:col-span-5 space-y-4">
        <img src={kitchenImg} alt="Dan Blaze testing a sauce in the South Brisbane kitchen" class="rounded-sm w-full aspect-[4/5] object-cover" />
        <figcaption class="text-xs font-mono uppercase tracking-wide text-dust text-right">Dan, sauce-testing, August 2024</figcaption>
      </div>
    </div>
  </section>

  {/* Values strip */}
  <section class="py-20 bg-ink border-y border-ember/20">
    <div class="wrap grid md:grid-cols-3 gap-10">
      <div>
        <div class="text-ember font-display text-5xl mb-4">01</div>
        <h3 class="text-xl text-bone mb-3">Small batches, always</h3>
        <p class="text-bone/70 leading-relaxed">Every bottle is cooked in 60-litre batches and tasted by both of us before it leaves the kitchen. No shortcuts. No contract co-packers. No "natural flavours".</p>
      </div>
      <div>
        <div class="text-ember font-display text-5xl mb-4">02</div>
        <h3 class="text-xl text-bone mb-3">Heat with a reason</h3>
        <p class="text-bone/70 leading-relaxed">We don't chase capsaicin records. Heat without flavour is a dare, not a sauce. Every chilli we use earns its spot on the label.</p>
      </div>
      <div>
        <div class="text-ember font-display text-5xl mb-4">03</div>
        <h3 class="text-xl text-bone mb-3">Australian-first</h3>
        <p class="text-bone/70 leading-relaxed">Queensland mangoes. Tasmanian pepperberry. Bunya nut smoke from the Sunshine Coast. Brisbane-roasted coffee. We source local, even when it's the harder road.</p>
      </div>
    </div>
  </section>

  {/* Timeline */}
  <section class="py-24">
    <div class="wrap">
      <p class="eyebrow">The timeline</p>
      <h2 class="text-4xl md:text-5xl text-bone mb-14">From 20 bottles to 45 stockists.</h2>
      <ol class="relative border-l-2 border-ember/30 pl-10 space-y-10">
        {timeline.map(t => (
          <li class="relative">
            <span class="absolute -left-[49px] top-1 w-6 h-6 rounded-full bg-ember flex items-center justify-center">
              <span class="w-2 h-2 rounded-full bg-ink"></span>
            </span>
            <div class="font-display text-ember text-3xl leading-none mb-2">{t.year}</div>
            <p class="text-bone/80 text-lg leading-relaxed max-w-xl">{t.text}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  {/* Photo grid */}
  <section class="py-12">
    <div class="wrap grid md:grid-cols-3 gap-4">
      <img src={marketImg} alt="" class="rounded-sm aspect-square object-cover" />
      <img src={warehouseImg} alt="" class="rounded-sm aspect-square object-cover" />
      <img src={kitchenImg} alt="" class="rounded-sm aspect-square object-cover" />
    </div>
  </section>

  {/* Press strip */}
  <section class="py-24">
    <div class="wrap max-w-3xl text-center">
      <p class="eyebrow">Press</p>
      <blockquote class="font-display text-2xl md:text-4xl text-bone leading-tight mb-8">
        "Widowmaker is the most interesting hot sauce to come out of Australia in a decade. Buy three bottles — one to hide."
      </blockquote>
      <div class="text-dust font-mono text-xs uppercase tracking-shout">Broadsheet Brisbane · 2024</div>
    </div>
  </section>

  {/* Hero callout */}
  <section class="relative py-28 overflow-hidden">
    <div class="absolute inset-0">
      <img src={flameImg} alt="" class="w-full h-full object-cover opacity-40" />
      <div class="absolute inset-0 bg-gradient-to-r from-ink via-ink/80 to-ink/20"></div>
    </div>
    <div class="wrap relative max-w-3xl">
      <h2 class="text-4xl md:text-6xl text-bone leading-tight mb-6">Come say hi at the markets.</h2>
      <p class="text-bone/80 text-lg mb-8">Saturdays at the Powerhouse, Sundays at West End. Bring water.</p>
      <a href="../stockists/" class="btn-primary">Find us</a>
    </div>
  </section>
</Base>
