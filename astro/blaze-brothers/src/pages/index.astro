---
import Base from '../layouts/Base.astro';
import Ticker from '../components/Ticker.astro';
import ProductCard from '../components/ProductCard.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { products } from '../data/products';
import { recipes } from '../data/recipes';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const featured = products.filter(p => ['widowmaker', 'blackbird', 'sunset-reaper'].includes(p.slug));
const recipeOfWeek = recipes.find(r => r.slug === 'widowmaker-wings')!;
const heroImg = 'https://images.unsplash.com/photo-1587241321921-91a834d6d191?w=2000&h=1400&fit=crop&q=80&auto=format';
const marketImg = 'https://images.unsplash.com/photo-1488459716781-31db52582fe9?w=1200&h=900&fit=crop&q=80&auto=format';
const brothersImg = 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=1200&h=900&fit=crop&q=80&auto=format';
---
<Base title="Blaze Brothers — Artisan Hot Sauce, BBQ Rubs & Spice | Brisbane">
  {/* Hero — 3-stack headline + heat scale */}
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img src={heroImg} alt="" class="w-full h-full object-cover opacity-45" />
      <div class="absolute inset-0 bg-gradient-to-b from-ink/85 via-smoke/80 to-smoke"></div>
      <div class="absolute inset-0 bg-char-grain mix-blend-screen"></div>
    </div>
    <div class="wrap relative py-20 md:py-32">
      <p class="font-mono text-ember text-xs md:text-sm uppercase tracking-shout mb-8">// Small batch · Brutally hot · Genuinely artisan</p>
      <h1 class="font-display uppercase text-bone tracking-[0.02em] leading-[0.85] mb-0">
        <span class="block text-[clamp(3rem,12vw,10rem)]">Not For</span>
        <span class="block text-[clamp(3rem,12vw,10rem)]">The Mild</span>
        <span class="block text-[clamp(3rem,12vw,10rem)] text-ember">Hearted.</span>
      </h1>

      <div class="mt-14 grid md:grid-cols-5 gap-10 items-start">
        <div class="md:col-span-3">
          <p class="text-bone/85 text-lg md:text-xl leading-relaxed mb-8 max-w-xl">
            Hand-crafted hot sauces and spice blends made in small batches from Australian-grown chillies. We don't do mild. We don't apologise for heat. We do do flavour — insane, complex, layered, built to be tasted, not just survived.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href={`${base}/shop/`} class="btn-primary">Shop the Heat</a>
            <a href={`${base}/stockists/`} class="btn-ghost">Find our Stall</a>
          </div>
        </div>

        <aside class="md:col-span-2 bg-ash/90 backdrop-blur border border-ember/30 rounded-sm p-6 md:p-8">
          <p class="font-mono text-[10px] uppercase tracking-shout text-ember mb-5">// Current lineup heat</p>
          <ul class="space-y-4">
            {[
              { label: 'Mild',    pct: 20 },
              { label: 'Medium',  pct: 45 },
              { label: 'Hot',     pct: 70 },
              { label: 'Extreme', pct: 95 },
            ].map(row => (
              <li class="flex items-center gap-4">
                <span class="font-mono text-[10px] uppercase tracking-shout text-dust w-16 shrink-0">{row.label}</span>
                <div class="flex-1 h-2 bg-ink rounded-full overflow-hidden">
                  <span class="block h-full bg-gradient-to-r from-flame to-ember" style={`width:${row.pct}%`}></span>
                </div>
                <span class="font-mono text-xs text-bone/60 w-8 text-right">{row.pct}%</span>
              </li>
            ))}
          </ul>
          <p class="font-mono text-[10px] uppercase tracking-shout text-dust/70 mt-6 pt-5 border-t border-bone/10">
            8 products · 2 brothers · 1 very small smoker
          </p>
        </aside>
      </div>
    </div>
    <div class="absolute bottom-0 inset-x-0 h-1 bg-ember"></div>
  </section>

  {/* Ticker */}
  <Ticker items={['Widowmaker','Blackbird','Sunset Reaper','Bush Smoulder','Brothers Rub','Ember Rub','Starter Flight','Low & Slow Trio']} />

  {/* Featured products */}
  <section class="py-24">
    <div class="wrap">
      <div class="flex items-end justify-between flex-wrap gap-6 mb-14">
        <div>
          <p class="eyebrow">The Lineup</p>
          <h2 class="text-4xl md:text-6xl text-bone">Three sauces.<br/>Infinite regret.</h2>
          <div class="divider mt-6"></div>
        </div>
        <a href={`${base}/shop/`} class="text-ember font-display uppercase tracking-shout text-sm hover:text-flame">See all sauces →</a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {featured.map(p => <ProductCard product={p} />)}
      </div>
    </div>
  </section>

  {/* Brothers story band */}
  <section class="relative py-28 bg-ink">
    <div class="wrap grid md:grid-cols-2 gap-14 items-center">
      <div class="relative">
        <img src={brothersImg} alt="The Blaze brothers in their South Brisbane kitchen" class="rounded-sm w-full aspect-[4/5] object-cover" />
        <div class="absolute -bottom-6 -right-6 bg-ember text-ink p-6 max-w-[220px] hidden md:block">
          <div class="font-display uppercase tracking-shout text-xs mb-1">Est.</div>
          <div class="font-display text-5xl leading-none">2019</div>
          <div class="text-xs mt-2 font-mono uppercase">South Brisbane</div>
        </div>
      </div>
      <div>
        <p class="eyebrow">Two brothers. One smoker.</p>
        <h2 class="text-4xl md:text-5xl text-bone mb-6">Started at the markets.<br/>Never left.</h2>
        <p class="text-bone/80 text-lg leading-relaxed mb-5">
          Dan &amp; Mick Blaze set up a trestle table at the Jan Powers Farmers Market in March 2019 with twenty bottles of Widowmaker and a hand-chalked price sign. They sold out by 9:30am.
        </p>
        <p class="text-bone/80 text-lg leading-relaxed mb-8">
          Five years on, they still bottle everything themselves in a tin shed off Montague Rd — just with more shelves, a proper smoker, and a queue at every market they show up to.
        </p>
        <a href={`${base}/about/`} class="btn-ghost">Read the full story</a>
      </div>
    </div>
  </section>

  {/* Recipe of the week — featured */}
  <section class="py-24">
    <div class="wrap">
      <div class="flex items-end justify-between flex-wrap gap-6 mb-14">
        <div>
          <p class="eyebrow">Recipe of the week</p>
          <h2 class="text-4xl md:text-6xl text-bone">This Sunday:<br/>{recipeOfWeek.name}.</h2>
          <div class="divider mt-6"></div>
        </div>
        <a href={`${base}/recipes/`} class="text-ember font-display uppercase tracking-shout text-sm hover:text-flame">All recipes →</a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <RecipeCard recipe={recipeOfWeek} featured />
        {recipes.slice(1, 3).map(r => <RecipeCard recipe={r} />)}
      </div>
    </div>
  </section>

  {/* Where to find us */}
  <section class="relative py-28 overflow-hidden">
    <div class="absolute inset-0">
      <img src={marketImg} alt="" class="w-full h-full object-cover opacity-30" />
      <div class="absolute inset-0 bg-gradient-to-r from-ink via-ink/80 to-ink/40"></div>
    </div>
    <div class="wrap relative">
      <div class="max-w-2xl">
        <p class="eyebrow">Every weekend</p>
        <h2 class="text-4xl md:text-5xl text-bone mb-6">Find us at the markets.</h2>
        <p class="text-bone/80 text-lg leading-relaxed mb-4">
          Saturdays at the Powerhouse. Sundays at West End. Free samples if you can handle them. We do a discount if you can name the sauce with your eyes closed.
        </p>
        <p class="text-bone/80 text-lg leading-relaxed mb-8">
          Not in Brisbane? We ship Australia-wide in 1-3 business days, and stock 45+ independent grocers, butchers and restaurants from Byron to Toowoomba.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href={`${base}/stockists/`} class="btn-primary">Find a stockist</a>
          <a href={`${base}/stockists/#wholesale`} class="btn-ghost">Wholesale enquiries</a>
        </div>
      </div>
    </div>
  </section>

  {/* Tagline strip */}
  <section class="bg-ember text-ink py-16">
    <div class="wrap text-center">
      <p class="font-display uppercase tracking-shout text-2xl md:text-4xl leading-tight">
        If it doesn't make you swear,<br class="hidden md:inline"/>we don't bottle it.
      </p>
    </div>
  </section>
</Base>
