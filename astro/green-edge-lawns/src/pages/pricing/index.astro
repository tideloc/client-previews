---
import Base from '../../layouts/Base.astro';
import PricingCard from '../../components/PricingCard.astro';
import { pricingPlans } from '../../data/pricingPlans';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const faqs = [
  {
    q: 'Is there a lock-in contract?',
    a: 'No. You can pause, skip or cancel any week — just let us know by SMS. We ask for a heads-up before noon the day prior so we can re-route.',
  },
  {
    q: 'What does "from $45" actually mean?',
    a: 'The $45 rate applies to standard 300m² blocks in our regular Shire rotation. Larger blocks, steep slopes, or extra-long grass on first-time mows get a fixed quote before we start — always in writing, never a surprise.',
  },
  {
    q: 'Do you charge extra for edging?',
    a: 'No. Full edging and whipper-snipping are included in every single mow, every single visit. If your previous mower was charging extra for it, you were being had.',
  },
  {
    q: 'What about green waste?',
    a: 'Clippings from weekly/fortnightly mows stay on-site (we blow them off hard surfaces and mulch them into the lawn). For cleanups, hedging and landscaping jobs, full removal is quoted up-front.',
  },
  {
    q: 'What if it rains?',
    a: 'We push to the next dry day and SMS you first. Rain or wet grass isn\'t good for the lawn or the mower blades, so we\'d rather reschedule than rush it.',
  },
  {
    q: 'Do you use weedkillers or chemicals?',
    a: 'Minimally, and never without asking first. Spot spraying of bindii and clover is offered as an extra in spring. We don\'t blanket-spray lawns and we won\'t use glyphosate near edible gardens.',
  },
  {
    q: 'How do I pay?',
    a: 'Invoice by email after each visit (or monthly if you\'re on a regular plan). Card, bank transfer or PayID — whichever suits. Regular clients can set up a standing order through their bank.',
  },
  {
    q: 'Are you insured?',
    a: 'Yes — full public liability to $20M, plus personal indemnity. Certificates available on request. Every team member is also police-checked.',
  },
];

const comparison = [
  { feature: 'Mow front & back lawn', weekly: true, fortnightly: true, oneoff: true },
  { feature: 'Full edging & whipper-snip', weekly: true, fortnightly: true, oneoff: true },
  { feature: 'Blow-off paths & driveway', weekly: true, fortnightly: true, oneoff: true },
  { feature: 'Same weekday every visit', weekly: true, fortnightly: true, oneoff: false },
  { feature: 'SMS when on the way', weekly: true, fortnightly: true, oneoff: true },
  { feature: 'Green-waste removal', weekly: 'On request', fortnightly: 'On request', oneoff: 'Quoted' },
  { feature: 'Spot weed spray (first month)', weekly: false, fortnightly: true, oneoff: false },
  { feature: 'Priority after-storm callout', weekly: true, fortnightly: false, oneoff: false },
  { feature: 'Lock-in contract', weekly: 'None', fortnightly: 'None', oneoff: 'None' },
];

const renderCell = (val: boolean | string) => {
  if (val === true) return '<svg class="text-turf mx-auto" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
  if (val === false) return '<span class="text-bark/30 font-mono text-sm">&mdash;</span>';
  return `<span class="text-bark/80 text-xs font-medium">${val}</span>`;
};
---
<Base title="Pricing — Green Edge Lawns &amp; Gardens" description="Honest fortnightly, weekly and one-off pricing for residential lawn care in the Sutherland Shire. No lock-ins, no sneaky add-ons.">

  <section class="bg-dew/70 py-16 md:py-24">
    <div class="wrap text-center">
      <p class="eyebrow">Pricing</p>
      <h1 class="font-display font-extrabold text-bark text-5xl md:text-6xl leading-tight mb-6 max-w-3xl mx-auto">Three plans. No lock-ins. No surprise invoices.</h1>
      <p class="text-bark/75 text-lg max-w-2xl mx-auto leading-relaxed">
        Every quote is fixed in writing before we start. These are the standard rates for 300m² blocks in our regular Shire rotation.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="wrap">
      <div class="grid md:grid-cols-3 gap-6 items-stretch">
        {pricingPlans.map((p, i) => <PricingCard plan={p} featured={i === 1} />)}
      </div>
    </div>
  </section>

  {/* Comparison */}
  <section class="py-16 bg-sand">
    <div class="wrap">
      <div class="text-center mb-12 max-w-2xl mx-auto">
        <p class="eyebrow">Plan comparison</p>
        <h2 class="font-display font-bold text-3xl md:text-4xl text-bark">What&rsquo;s included.</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full bg-cream rounded-2xl overflow-hidden border border-bark/10">
          <thead>
            <tr class="bg-turf text-cream">
              <th class="text-left px-6 py-4 font-display font-semibold text-sm">What you get</th>
              <th class="text-center px-4 py-4 font-display font-semibold text-sm">Weekly</th>
              <th class="text-center px-4 py-4 font-display font-semibold text-sm bg-moss">Fortnightly</th>
              <th class="text-center px-4 py-4 font-display font-semibold text-sm">One-off</th>
            </tr>
          </thead>
          <tbody>
            {comparison.map((row, i) => (
              <tr class={i % 2 === 0 ? 'bg-cream' : 'bg-dew/30'}>
                <td class="px-6 py-4 text-bark/85 text-sm">{row.feature}</td>
                <td class="px-4 py-4 text-center" set:html={renderCell(row.weekly)}></td>
                <td class="px-4 py-4 text-center bg-dew/70" set:html={renderCell(row.fortnightly)}></td>
                <td class="px-4 py-4 text-center" set:html={renderCell(row.oneoff)}></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  {/* Add-ons */}
  <section class="py-16">
    <div class="wrap">
      <div class="text-center mb-12 max-w-2xl mx-auto">
        <p class="eyebrow">Optional add-ons</p>
        <h2 class="font-display font-bold text-3xl md:text-4xl text-bark">For when the lawn needs extra love.</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { name: 'Bindii weed spray', price: '$40 / visit', note: 'Spot spray only. Spring &amp; autumn.' },
          { name: 'Spring scalp &amp; overseed', price: 'From $260', note: 'Kikuyu or Sir Walter. Booked September.' },
          { name: 'Fertiliser drop', price: '$90 / visit', note: 'Scotts slow-release. Every 3 months.' },
          { name: 'Core aeration', price: 'From $310', note: 'Hired walk-behind. Heavy clay only.' },
          { name: 'Gutter clear (single-storey)', price: '$110', note: 'Done on same visit as a mow.' },
          { name: 'Dethatch (rolled lawns)', price: 'From $180', note: 'Annual, October-ish.' },
        ].map(a => (
          <div class="card p-6">
            <div class="flex items-baseline justify-between gap-3 mb-2">
              <h3 class="font-display font-semibold text-bark text-lg" set:html={a.name}></h3>
              <span class="font-mono text-xs text-turf whitespace-nowrap">{a.price}</span>
            </div>
            <p class="text-bark/70 text-sm" set:html={a.note}></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* FAQ */}
  <section class="py-16 bg-dew/60">
    <div class="wrap max-w-3xl">
      <div class="text-center mb-12">
        <p class="eyebrow">Before you ask</p>
        <h2 class="font-display font-bold text-3xl md:text-4xl text-bark">The usual questions.</h2>
      </div>
      <dl class="space-y-4">
        {faqs.map(faq => (
          <details class="group card p-6">
            <summary class="flex items-center justify-between cursor-pointer list-none gap-4">
              <dt class="font-display font-semibold text-bark text-lg">{faq.q}</dt>
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-dew flex items-center justify-center group-open:bg-turf group-open:text-cream transition">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="transition group-open:rotate-45"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </span>
            </summary>
            <dd class="mt-4 text-bark/75 leading-relaxed">{faq.a}</dd>
          </details>
        ))}
      </dl>
    </div>
  </section>

  {/* CTA */}
  <section class="py-16">
    <div class="wrap">
      <div class="bg-turf text-cream rounded-2xl p-10 md:p-14 text-center">
        <h2 class="font-display font-bold text-3xl md:text-4xl mb-4">A straight answer in 60 seconds.</h2>
        <p class="text-cream/85 text-lg mb-8 max-w-xl mx-auto">Send us your address and a photo. We quote the same day if you message before 4pm.</p>
        <a href={`${base}/contact/`} class="btn-accent">Get my exact price</a>
      </div>
    </div>
  </section>
</Base>
