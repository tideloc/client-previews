---
import Base from '../layouts/Base.astro';
import ServiceCard from '../components/ServiceCard.astro';
import PricingCard from '../components/PricingCard.astro';
import BeforeAfterCard from '../components/BeforeAfterCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import { services, pickServices } from '../data/services';
import { pricingPlans } from '../data/pricingPlans';
import { jobs } from '../data/jobs';
import { testimonials } from '../data/testimonials';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const heroImg = 'https://images.unsplash.com/photo-1558904541-efa843a96f01?w=2000&h=1300&fit=crop&q=80&auto=format';
const featuredServices = pickServices(['mowing', 'hedging', 'cleanups', 'landscaping']);
const featuredJobs = [jobs[0], jobs[1], jobs[3]];
const featuredTestimonials = testimonials.slice(0, 3);

const days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri'];
---
<Base title="Green Edge Lawns &amp; Gardens — Reliable Lawn Care, Sutherland Shire">
  {/* Hero */}
  <section class="relative overflow-hidden bg-dew">
    <div class="absolute inset-0 bg-grass-grain"></div>
    <div class="wrap relative grid md:grid-cols-2 gap-12 py-16 md:py-24 items-center">
      <div>
        <span class="chip mb-6">
          <span class="w-2 h-2 rounded-full bg-turf"></span>
          Booking Shire-wide for May
        </span>
        <h1 class="font-display font-extrabold text-bark leading-[0.95] text-5xl md:text-7xl mb-6">
          A tidy lawn.<br/>
          <span class="text-turf">Every week.</span><br/>
          Like clockwork.
        </h1>
        <p class="text-bark/75 text-lg leading-relaxed max-w-lg mb-8">
          Residential lawn care and small landscaping across the Sutherland Shire. We turn up on the day we said. Your mum doesn&rsquo;t have to remind you.
        </p>
        <div class="flex flex-wrap gap-4 mb-10">
          <a href={`${base}/contact/`} class="btn-primary">Get a free quote</a>
          <a href={`${base}/pricing/`} class="btn-ghost">See pricing</a>
        </div>
        <div class="flex items-center gap-6 text-sm text-bark/70">
          <div class="flex items-center gap-2">
            <svg class="text-turf" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Fully insured
          </div>
          <div class="flex items-center gap-2">
            <svg class="text-turf" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Police-checked team
          </div>
          <div class="flex items-center gap-2">
            <svg class="text-sunshine" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            4.9 on Google
          </div>
        </div>
      </div>
      <div class="relative">
        <div class="relative aspect-[4/5] rounded-2xl overflow-hidden shadow-xl bg-bark/5">
          <img src={heroImg} alt="Freshly mowed lawn with clean stripes in a Sutherland Shire backyard" class="w-full h-full object-cover" />
        </div>
        <div class="absolute -bottom-6 -left-6 bg-cream rounded-2xl shadow-lg p-5 max-w-[220px] hidden md:block border border-bark/5">
          <div class="flex items-center gap-2 mb-3">
            <span class="w-2 h-2 rounded-full bg-turf animate-pulse"></span>
            <div class="font-mono text-[10px] uppercase tracking-widest text-moss">This week's route</div>
          </div>
          <div class="grid grid-cols-5 gap-1.5">
            {days.map((d, i) => (
              <div class={`text-center rounded-lg px-1.5 py-2 ${i === 2 ? 'bg-turf text-cream' : 'bg-dew text-turf'}`}>
                <div class="font-mono text-[9px] uppercase">{d}</div>
                <div class="font-display font-bold text-sm mt-0.5">{22 + i}</div>
              </div>
            ))}
          </div>
          <div class="text-xs text-bark/70 mt-3 leading-snug">You&rsquo;re on the <strong class="text-turf">Wed Cronulla</strong> run.</div>
        </div>
        <div class="absolute -top-4 -right-4 bg-sunshine text-bark px-5 py-4 rounded-2xl shadow-lg hidden md:block">
          <div class="font-display font-bold text-2xl leading-none">$45</div>
          <div class="font-mono text-[10px] uppercase tracking-widest mt-1">per mow · from</div>
        </div>
      </div>
    </div>
  </section>

  {/* Services */}
  <section class="py-20">
    <div class="wrap">
      <div class="flex items-end justify-between flex-wrap gap-6 mb-12">
        <div class="max-w-xl">
          <p class="eyebrow">What we do</p>
          <h2 class="text-4xl md:text-5xl font-bold text-bark leading-tight">The whole yard, handled.</h2>
          <div class="divider mt-6"></div>
        </div>
        <a href={`${base}/services/`} class="font-display font-medium text-sm text-turf hover:text-moss">See all 8 services &rarr;</a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {featuredServices.map(s => <ServiceCard service={s} compact />)}
      </div>
    </div>
  </section>

  {/* How it works */}
  <section class="py-20 bg-dew/60">
    <div class="wrap">
      <div class="max-w-xl mb-12">
        <p class="eyebrow">How it works</p>
        <h2 class="text-4xl md:text-5xl font-bold text-bark leading-tight">Three steps.<br/>No messing.</h2>
        <div class="divider mt-6"></div>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { n: '01', title: 'Free quote', body: 'Tell us the address and show a photo. Most quotes go back the same day — bigger jobs we visit on-site within 48 hours.' },
          { n: '02', title: 'Locked-in day', body: 'We slot you into a regular route — same weekday every week or fortnight. You get an SMS on the way.' },
          { n: '03', title: 'Tidy lawn, paid easily', body: 'Job done, photo sent, invoice drops by email. Pay by card, bank transfer or standing order. No lock-in.' },
        ].map(step => (
          <div class="card p-8">
            <div class="font-mono text-4xl font-bold text-leaf mb-4">{step.n}</div>
            <h3 class="font-display font-bold text-2xl text-bark mb-3">{step.title}</h3>
            <p class="text-bark/75 leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Pricing */}
  <section class="py-20">
    <div class="wrap">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="eyebrow">Simple pricing</p>
        <h2 class="text-4xl md:text-5xl font-bold text-bark leading-tight">Same price. Every week. No sneaky add-ons.</h2>
        <p class="text-bark/70 mt-6 text-lg">Prices shown are for a standard 300m² block with front &amp; back lawn. Bigger blocks get a fixed quote up-front.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6 items-stretch">
        {pricingPlans.map((p, i) => <PricingCard plan={p} featured={i === 1} />)}
      </div>
      <p class="text-center text-sm text-bark/60 mt-8">
        Prefer a one-off? Minimum call-out is <span class="text-bark font-medium">$110</span> — no hidden fees.
      </p>
    </div>
  </section>

  {/* Before / After */}
  <section class="py-20 bg-sand">
    <div class="wrap">
      <div class="flex items-end justify-between flex-wrap gap-6 mb-12">
        <div class="max-w-xl">
          <p class="eyebrow">Recent work</p>
          <h2 class="text-4xl md:text-5xl font-bold text-bark leading-tight">Before &amp; after,<br/>across the Shire.</h2>
          <div class="divider mt-6"></div>
        </div>
        <a href={`${base}/gallery/`} class="font-display font-medium text-sm text-turf hover:text-moss">See all 10 jobs &rarr;</a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {featuredJobs.map(j => <BeforeAfterCard job={j} />)}
      </div>
    </div>
  </section>

  {/* Service area */}
  <section class="py-20">
    <div class="wrap grid md:grid-cols-2 gap-12 items-center">
      <div class="relative">
        <div class="relative aspect-square rounded-2xl overflow-hidden bg-dew">
          <img src="https://images.unsplash.com/photo-1566150905458-1bf1fc113f0d?w=1200&h=1200&fit=crop&q=80&auto=format" alt="Sutherland Shire coastline" class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-turf/70 via-turf/20 to-transparent"></div>
          <div class="absolute bottom-8 left-8 right-8 text-cream">
            <div class="font-mono text-[10px] uppercase tracking-widest mb-2 opacity-80">Service area</div>
            <div class="font-display font-bold text-3xl">Cronulla &rarr; Engadine</div>
            <div class="font-display text-lg opacity-90">and everything in between</div>
          </div>
        </div>
      </div>
      <div>
        <p class="eyebrow">The Shire, handled</p>
        <h2 class="text-4xl md:text-5xl font-bold text-bark leading-tight mb-6">Local lads. Local rounds.</h2>
        <p class="text-bark/75 leading-relaxed text-lg mb-6">
          We stay inside the Shire on purpose. It means tighter routes, same-day callouts after storms, and the green-waste trip back to Kurnell is twenty minutes — not two hours.
        </p>
        <div class="grid grid-cols-2 gap-2 mb-8 text-sm text-bark/80">
          {['Cronulla','Caringbah','Miranda','Gymea','Kirrawee','Sylvania','Jannali','Oyster Bay','Engadine','Woolooware','Menai','Yowie Bay'].map(s => (
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-leaf"></span>
              {s}
            </div>
          ))}
        </div>
        <a href={`${base}/service-area/`} class="btn-primary">See full list</a>
      </div>
    </div>
  </section>

  {/* Testimonials */}
  <section class="py-20 bg-dew/60">
    <div class="wrap">
      <div class="max-w-xl mb-12">
        <p class="eyebrow">Word from the clients</p>
        <h2 class="text-4xl md:text-5xl font-bold text-bark leading-tight">Reviews the neighbours can verify.</h2>
        <div class="divider mt-6"></div>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {featuredTestimonials.map(t => <TestimonialCard testimonial={t} />)}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="py-20">
    <div class="wrap">
      <div class="rounded-2xl bg-turf text-cream p-10 md:p-16 grid md:grid-cols-5 gap-8 items-center overflow-hidden relative">
        <div class="absolute -right-20 -bottom-20 w-80 h-80 rounded-full bg-moss opacity-50"></div>
        <div class="absolute right-20 -top-10 w-40 h-40 rounded-full bg-leaf opacity-30"></div>
        <div class="md:col-span-3 relative">
          <h2 class="font-display font-bold text-3xl md:text-4xl leading-tight mb-4">Ready for a lawn you don&rsquo;t have to think about?</h2>
          <p class="text-cream/85 text-lg leading-relaxed">Free quote back today if you message before 4pm.</p>
        </div>
        <div class="md:col-span-2 flex flex-wrap gap-3 relative">
          <a href={`${base}/contact/`} class="btn-accent flex-1 justify-center">Get my quote</a>
          <a href="tel:0412987654" class="inline-flex items-center justify-center gap-2 border-2 border-cream/40 text-cream px-6 py-3 font-display font-semibold text-sm rounded-2xl hover:border-cream hover:bg-cream/10 transition flex-1">
            0412 987 654
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
