---
import type { BreweryEvent } from '../data/events';
interface Props { event: BreweryEvent }
const { event } = Astro.props;
---
<article
  class="group bg-cream rounded-enamel overflow-hidden flex flex-col"
  style="box-shadow: inset 0 0 0 2px rgba(26,20,16,0.12);"
>
  <div class="relative aspect-[5/3] overflow-hidden bg-stout">
    <img src={event.image} alt={event.title} class="w-full h-full object-cover group-hover:scale-[1.03] transition duration-500" />
    <div class="absolute top-3 left-3 bg-stout text-cream px-3 py-2 rounded-enamel text-center leading-none"
         style="box-shadow: inset 0 0 0 2px rgba(247,239,224,0.2);">
      <div class="font-mono text-[10px] uppercase tracking-wide2 text-grain">{event.month}</div>
      <div class="font-display italic text-2xl mt-0.5">{event.day}</div>
    </div>
  </div>
  <div class="p-5">
    <div class="flex items-center gap-3 mb-2">
      <span class="pill-ember">{event.kind}</span>
      <span class="font-mono text-[10px] uppercase tracking-wide2 text-shadow">{event.time}</span>
    </div>
    <h3 class="text-stout text-xl leading-tight mb-2">{event.title}</h3>
    <p class="text-stout/75 text-sm leading-relaxed">{event.blurb}</p>
  </div>
</article>
