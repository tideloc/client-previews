---
import Base from '../../layouts/Base.astro';
import { team } from '../../data/team';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const hero = 'https://images.unsplash.com/photo-1518644961665-ed172691aaa1?w=2200&h=1200&fit=crop&q=80&auto=format';

const equipment = [
  {
    name: '1922 Alldays & Onions Blower',
    spec: 'Hand-cranked · Sheffield · Restored 2015',
    blurb:
      "Salvaged from a disused shearing shed near Goulburn. Needed new leather vanes, a replacement crank handle from a lathe-turn mate in Tallaganda, and a lot of patience. She's been in daily use since 2016.",
    image: 'https://images.unsplash.com/photo-1534237710431-e2fc698436d0?w=1200&h=900&fit=crop&q=80&auto=format',
  },
  {
    name: 'Primary coal forge',
    spec: '600mm × 450mm hearth · welsh steam coal',
    blurb:
      "Brick-built by Tom over six weeks in 2014, banded with mild-steel strap and lined with refractory cement. Fed by the Alldays blower. Runs Welsh anthracite — the only kind worth the money.",
    image: 'https://images.unsplash.com/photo-1565688527174-775059ac429c?w=1200&h=900&fit=crop&q=80&auto=format',
  },
  {
    name: 'Peter Wright 250kg anvil',
    spec: 'Dudley · c.1890 · rebound 89%',
    blurb:
      'The main anvil. Cast-iron body with a tool-steel face, Dudley-stamped. Rings like a church bell. The face has been dressed once in a hundred-odd years — by us, gently, in 2014.',
    image: 'https://images.unsplash.com/photo-1502082553048-f009c37129b9?w=1200&h=900&fit=crop&q=80&auto=format',
  },
  {
    name: "Sara's MIG rig + CAD station",
    spec: 'Kemppi Minarc · Fusion 360',
    blurb:
      "For the architectural work — where drawings, CNC and MIG live alongside the hammer. Sara runs the whole digital side of the shop from here. The forge will always win a debate, but the drawings have to be right first.",
    image: 'https://images.unsplash.com/photo-1504826260979-242151ee45b7?w=1200&h=900&fit=crop&q=80&auto=format',
  },
];
---
<Base title="About · Two Makers in Braidwood — The Forge Works">
  {/* Hero */}
  <section class="relative overflow-hidden border-b border-bone/10">
    <div class="absolute inset-0">
      <img src={hero} alt="" class="w-full h-full object-cover opacity-35" />
      <div class="absolute inset-0 bg-gradient-to-b from-soot/85 via-forge/85 to-forge"></div>
    </div>
    <div class="wrap relative py-20 md:py-28">
      <p class="eyebrow">// About the studio</p>
      <h1 class="text-5xl md:text-7xl text-bone leading-[0.9] mb-6 normal-case">A tin shed.<br/>A coal fire.<br/>Ten years in.</h1>
      <p class="text-bone/80 text-lg max-w-2xl leading-relaxed">
        The Forge Works started in 2014 when Tom Halloran and Sara Chen took over a disused fencing-contractor's shed on the back of a 2-acre block in Braidwood. We've been here since.
      </p>
    </div>
  </section>

  {/* Studio story */}
  <section class="py-20 md:py-28">
    <div class="wrap grid md:grid-cols-12 gap-12 items-start">
      <div class="md:col-span-4">
        <p class="eyebrow">// The studio</p>
        <h2 class="text-4xl md:text-5xl text-bone mb-6 normal-case">How we got here.</h2>
        <div class="divider mb-10"></div>
        <dl class="grid grid-cols-2 gap-3">
          <div class="spec-block"><dt>Founded</dt><dd class="text-3xl">2014</dd></div>
          <div class="spec-block"><dt>Town</dt><dd class="text-xl">Braidwood</dd></div>
          <div class="spec-block"><dt>Postcode</dt><dd class="text-xl">2622</dd></div>
          <div class="spec-block"><dt>Projects</dt><dd class="text-3xl">112</dd></div>
        </dl>
      </div>
      <div class="md:col-span-8 space-y-6 text-bone/85 text-lg leading-relaxed">
        <p>Tom trained in Yorkshire under Peter Dyson and spent seven years there before moving back to Australia in 2010. Sara came through RMIT's sculpture program and cut her teeth on architect-led projects in Melbourne and country Victoria. They met on a job in Castlemaine in 2017 and pooled the two practices into one shed shortly after.</p>
        <p>The place works like this: Tom runs the heritage commissions and the weekend classes. Sara runs the architectural work, the CAD, and all the drawings that go out to builders. Most projects pass through both of us. We make everything here — no production is outsourced. If it has our name on it, one of us forged it.</p>
        <p>We don't have a big shopfront. We don't have a catalogue that turns over each season. Work takes the time it takes. The shed is cold in winter, the forge runs hot, and every three or four months someone drives out from Canberra or Sydney with an impossible brief and a photograph of a doorknob their grandmother once loved. We mostly say yes.</p>
      </div>
    </div>
  </section>

  {/* Maker bios */}
  <section id="makers" class="py-20 md:py-24 bg-soot border-y border-bone/10">
    <div class="wrap">
      <p class="eyebrow">// The two makers</p>
      <h2 class="text-4xl md:text-5xl text-bone mb-14 normal-case">Tom &amp; Sara.</h2>
      <div class="grid md:grid-cols-2 gap-10">
        {team.map((m, i) => (
          <article class="chamber bg-anvil/60 p-8">
            <div class="flex items-start gap-5 mb-6">
              <img src={m.image} alt={m.name} class="w-24 h-24 object-cover bg-soot" />
              <div>
                <p class="font-mono uppercase tracking-stamp text-[11px] text-glow mb-2">0{i + 1} · {m.discipline}</p>
                <h3 class="text-bone text-3xl normal-case">{m.name}</h3>
                <p class="font-mono uppercase tracking-stamp text-[11px] text-bone/55 mt-1">{m.role}</p>
              </div>
            </div>
            <p class="text-bone/85 leading-relaxed mb-4">{m.bio}</p>
            <p class="text-glow font-mono uppercase tracking-stamp text-[11px]">{m.tagline} · {m.years} years at the anvil</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* Equipment list */}
  <section id="equipment" class="py-20 md:py-28">
    <div class="wrap">
      <div class="flex items-end justify-between flex-wrap gap-4 mb-12">
        <div>
          <p class="eyebrow">// The equipment</p>
          <h2 class="text-4xl md:text-5xl text-bone normal-case">Tools with history.</h2>
        </div>
        <span class="spec">Four of the important ones</span>
      </div>
      <div class="grid md:grid-cols-2 gap-10">
        {equipment.map((e, i) => (
          <article class="group">
            <div class="relative overflow-hidden bg-soot mb-5">
              <img src={e.image} alt={e.name} class="w-full aspect-[4/3] object-cover opacity-85 group-hover:opacity-100 transition" />
              <span class="absolute top-3 left-3 bg-rust text-bone px-2 py-1 font-mono uppercase tracking-stamp text-[10px]">0{i + 1}</span>
            </div>
            <h3 class="text-bone text-2xl mb-2 normal-case">{e.name}</h3>
            <p class="font-mono uppercase tracking-stamp text-[10px] text-glow mb-4">{e.spec}</p>
            <p class="text-bone/75 text-sm leading-relaxed">{e.blurb}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* Visit */}
  <section id="visit" class="py-20 md:py-24 bg-rust/5 border-y border-rust/30">
    <div class="wrap grid md:grid-cols-12 gap-10 items-start">
      <div class="md:col-span-5">
        <p class="eyebrow">// Drop by</p>
        <h2 class="text-4xl md:text-5xl text-bone mb-6 normal-case">Visit by<br/>appointment.</h2>
        <div class="divider mb-8"></div>
        <p class="text-bone/85 text-lg leading-relaxed mb-4">We're an hour east of Canberra, an hour west of Bateman's Bay, on the way to basically anywhere on the south coast.</p>
        <p class="text-bone/85 text-lg leading-relaxed">Text ahead and we'll put the kettle on. The forge lights on Tuesdays, Wednesdays, Thursdays, and every second Saturday.</p>
      </div>
      <div class="md:col-span-7 chamber bg-soot/70 p-8">
        <dl class="grid md:grid-cols-2 gap-6">
          <div>
            <dt class="font-mono uppercase tracking-stamp text-[11px] text-glow mb-2">Address</dt>
            <dd class="text-bone/90 leading-relaxed">The Forge Works<br/>42 Wilson St<br/>Braidwood NSW 2622</dd>
          </div>
          <div>
            <dt class="font-mono uppercase tracking-stamp text-[11px] text-glow mb-2">Contact</dt>
            <dd class="text-bone/90 leading-relaxed">
              <a href="mailto:hello@theforgeworks.com.au" class="hover:text-glow">hello@theforgeworks.com.au</a><br/>
              02 4842 0100<br/>
              Tuesday–Saturday
            </dd>
          </div>
          <div>
            <dt class="font-mono uppercase tracking-stamp text-[11px] text-glow mb-2">For architects</dt>
            <dd class="text-bone/90 leading-relaxed">Send plans in advance. Tuesday-Thursday is best for drawings review. Budget 90 minutes.</dd>
          </div>
          <div>
            <dt class="font-mono uppercase tracking-stamp text-[11px] text-glow mb-2">For heritage</dt>
            <dd class="text-bone/90 leading-relaxed">Bring the piece or photographs. We keep a pattern library going back to 1825.</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <section class="bg-soot py-16 border-t border-bone/10">
    <div class="wrap text-center">
      <p class="font-display text-3xl md:text-4xl leading-tight tracking-chisel mb-6 normal-case">Bring us a brief.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href={`${base}/projects/#commission`} class="btn-primary">Start a commission</a>
        <a href={`${base}/workshops/`} class="btn-ghost">Book a workshop</a>
      </div>
    </div>
  </section>
</Base>
