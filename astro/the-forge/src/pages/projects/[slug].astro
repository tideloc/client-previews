---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { projects, projectTypeLabel } from '../../data/projects';

export function getStaticPaths() {
  return projects.map(p => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const more = projects.filter(p => p.slug !== project.slug).slice(0, 2);
---
<Base title={`${project.name} — The Forge Works`} description={project.blurb}>
  <section class="pt-12 pb-16 border-b border-bone/10">
    <div class="wrap">
      <nav class="text-xs font-mono uppercase tracking-stamp text-bone/55 mb-10">
        <a href={`${base}/projects/`} class="hover:text-glow">Projects</a>
        <span class="mx-2 text-bone/30">/</span>
        <span class="text-bone/65">{projectTypeLabel[project.type]}</span>
        <span class="mx-2 text-bone/30">/</span>
        <span class="text-glow">{project.name}</span>
      </nav>

      <div class="grid md:grid-cols-12 gap-10">
        <div class="md:col-span-5">
          <p class="eyebrow">// {projectTypeLabel[project.type]} · {project.year}</p>
          <h1 class="text-5xl md:text-6xl text-bone leading-[0.9] mb-6 normal-case">{project.name}</h1>
          <p class="text-bone/55 text-sm font-mono uppercase tracking-stamp mb-8">{project.client}</p>
          <p class="text-bone/85 text-lg leading-relaxed mb-8">{project.brief}</p>
          <div class="divider mb-8"></div>
          <p class="text-bone/80 text-base leading-relaxed">{project.description}</p>
        </div>
        <div class="md:col-span-7">
          <img src={project.images[0]} alt={project.name} class="w-full aspect-[4/3] object-cover bg-anvil" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-soot border-b border-bone/10">
    <div class="wrap">
      <p class="eyebrow">// Spec sheet</p>
      <div class="grid md:grid-cols-4 gap-3 mb-12">
        <div class="spec-block">
          <dt>Hours in workshop</dt>
          <dd class="text-3xl">{project.hours}</dd>
        </div>
        <div class="spec-block">
          <dt>Year completed</dt>
          <dd class="text-3xl">{project.year}</dd>
        </div>
        <div class="spec-block">
          <dt>Project type</dt>
          <dd class="text-xl">{projectTypeLabel[project.type]}</dd>
        </div>
        <div class="spec-block">
          <dt>Materials</dt>
          <dd class="text-xl">{project.materials.length} elements</dd>
        </div>
      </div>
      <div class="grid md:grid-cols-2 gap-10">
        <div>
          <h3 class="font-mono uppercase tracking-stamp text-glow text-[11px] mb-4">Materials used</h3>
          <ul class="space-y-2 text-bone/80">
            {project.materials.map(m => (
              <li class="flex gap-3 text-sm"><span class="font-mono text-rust">—</span>{m}</li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-mono uppercase tracking-stamp text-glow text-[11px] mb-4">Client</h3>
          <p class="text-bone/80 text-sm leading-relaxed mb-6">{project.client}</p>
          <h3 class="font-mono uppercase tracking-stamp text-glow text-[11px] mb-4">Brief</h3>
          <p class="text-bone/80 text-sm leading-relaxed">{project.brief}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="wrap">
      <p class="eyebrow">// Process</p>
      <h2 class="text-3xl md:text-4xl text-bone mb-10 normal-case">Drawn, forged, fitted.</h2>
      <div class="grid md:grid-cols-3 gap-4">
        <figure>
          <img src={project.images[0]} alt={`${project.name} — drawn`} class="w-full aspect-[4/5] object-cover bg-anvil" />
          <figcaption class="mt-3 font-mono uppercase tracking-stamp text-[10px] text-bone/55">01 · Drawing &amp; pattern</figcaption>
        </figure>
        <figure>
          <img src={project.images[1]} alt={`${project.name} — forging`} class="w-full aspect-[4/5] object-cover bg-anvil" />
          <figcaption class="mt-3 font-mono uppercase tracking-stamp text-[10px] text-bone/55">02 · On the anvil</figcaption>
        </figure>
        <figure>
          <img src={project.images[2]} alt={`${project.name} — installed`} class="w-full aspect-[4/5] object-cover bg-anvil" />
          <figcaption class="mt-3 font-mono uppercase tracking-stamp text-[10px] text-bone/55">03 · Installed</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="py-16 bg-soot border-t border-bone/10">
    <div class="wrap">
      <div class="flex items-end justify-between mb-10">
        <h2 class="text-3xl md:text-4xl text-bone normal-case">More projects</h2>
        <a href={`${base}/projects/`} class="text-glow font-mono uppercase tracking-stamp text-xs hover:text-bone">All projects →</a>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {more.map(p => <ProjectCard project={p} />)}
      </div>
    </div>
  </section>

  <section class="bg-rust text-bone py-16 border-t border-rust">
    <div class="wrap text-center">
      <p class="font-display text-3xl md:text-4xl leading-tight tracking-chisel mb-6 normal-case">Have a project like this?</p>
      <a href={`${base}/projects/#commission`} class="inline-flex items-center gap-2 bg-soot text-bone px-7 py-3 font-mono uppercase tracking-stamp text-xs hover:bg-forge">Start a commission</a>
    </div>
  </section>
</Base>
