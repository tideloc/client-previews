---
import Base from '../../layouts/Base.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products, categoryLabel } from '../../data/products';

export function getStaticPaths() {
  return products.map(p => ({ params: { slug: p.slug }, props: { product: p } }));
}

const { product } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const related = products.filter(p => p.slug !== product.slug && p.category === product.category).slice(0, 3);
const backup = products.filter(p => p.slug !== product.slug).slice(0, 3);
const show = related.length >= 2 ? related : backup;
---
<Base title={`${product.name} — The Forge Works`} description={product.blurb}>
  <section class="pt-12 pb-20 border-b border-bone/10">
    <div class="wrap">
      <nav class="text-xs font-mono uppercase tracking-stamp text-bone/55 mb-10">
        <a href={`${base}/shop/`} class="hover:text-glow">Shop</a>
        <span class="mx-2 text-bone/30">/</span>
        <span class="text-bone/65">{categoryLabel[product.category]}</span>
        <span class="mx-2 text-bone/30">/</span>
        <span class="text-glow">{product.name}</span>
      </nav>

      <div class="grid md:grid-cols-2 gap-14">
        <div class="relative bg-anvil overflow-hidden chamber">
          <img src={product.image} alt={product.name} class="w-full aspect-[4/5] object-cover" />
          {product.badge && (
            <span class="absolute top-5 left-5 bg-rust text-bone px-3 py-1 font-mono uppercase tracking-stamp text-[11px]">{product.badge}</span>
          )}
          <span class="absolute bottom-5 left-5 font-mono uppercase tracking-stamp text-[10px] text-bone/70 bg-soot/70 px-2 py-1">{product.dimensions}</span>
        </div>
        <div>
          <p class="eyebrow">// {categoryLabel[product.category]}</p>
          <h1 class="text-5xl md:text-6xl text-bone leading-[0.95] mb-4 normal-case">{product.name}</h1>
          <p class="text-glow text-lg font-display tracking-chisel mb-6 normal-case">{product.blurb}</p>

          <dl class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-8">
            <div class="spec-block">
              <dt>Price</dt>
              <dd>${product.price}</dd>
            </div>
            <div class="spec-block">
              <dt>Weight</dt>
              <dd>{product.weight}</dd>
            </div>
            <div class="spec-block">
              <dt>Lead</dt>
              <dd>{product.leadTime}</dd>
            </div>
            <div class="spec-block">
              <dt>Type</dt>
              <dd class="capitalize">{product.category}</dd>
            </div>
          </dl>

          <p class="text-bone/80 text-lg leading-relaxed mb-10">{product.description}</p>

          <div class="flex items-center gap-4 mb-12">
            <div class="flex items-center border border-bone/20">
              <button class="w-10 h-12 text-bone hover:text-glow" aria-label="Decrease quantity">−</button>
              <span class="w-12 text-center font-display text-lg text-bone">1</span>
              <button class="w-10 h-12 text-bone hover:text-glow" aria-label="Increase quantity">+</button>
            </div>
            <button class="btn-primary flex-1">Add to cart · ${product.price}</button>
          </div>

          <dl class="space-y-6 text-sm border-t border-bone/10 pt-8">
            <div>
              <dt class="font-mono uppercase tracking-stamp text-glow text-[11px] mb-2">Material</dt>
              <dd class="text-bone/80">{product.material}</dd>
            </div>
            <div>
              <dt class="font-mono uppercase tracking-stamp text-glow text-[11px] mb-2">Finish</dt>
              <dd class="text-bone/80">{product.finish}</dd>
            </div>
            <div>
              <dt class="font-mono uppercase tracking-stamp text-glow text-[11px] mb-2">Dimensions</dt>
              <dd class="text-bone/80">{product.dimensions} · {product.weight}</dd>
            </div>
            <div>
              <dt class="font-mono uppercase tracking-stamp text-glow text-[11px] mb-2">Care</dt>
              <dd class="text-bone/80">Wipe with a dry cloth. Re-wax annually with beeswax or boiled linseed. Do not varnish. If it develops a patina you hate, steel-wool it back and re-oil.</dd>
            </div>
            <div>
              <dt class="font-mono uppercase tracking-stamp text-glow text-[11px] mb-2">Custom variations</dt>
              <dd class="text-bone/80">Larger, smaller, left-handed, different finish, different back-plate, matched sets — most of what you can ask for, we can do. <a href={`${base}/projects/#commission`} class="text-glow hover:text-bone underline decoration-rust/50">Start a commission →</a></dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  {show.length > 0 && (
    <section class="py-20 bg-soot">
      <div class="wrap">
        <div class="flex items-end justify-between mb-10">
          <div>
            <p class="eyebrow">// You might also like</p>
            <h2 class="text-3xl md:text-4xl text-bone normal-case">Pairs nicely.</h2>
          </div>
          <a href={`${base}/shop/`} class="text-glow font-mono uppercase tracking-stamp text-xs hover:text-bone">Back to shop →</a>
        </div>
        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
          {show.map(p => <ProductCard product={p} />)}
        </div>
      </div>
    </section>
  )}
</Base>
