---
import Base from '../../layouts/Base.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products } from '../../data/products';

export function getStaticPaths() {
  return products.map(p => ({ params: { slug: p.slug }, props: { product: p } }));
}

const { product } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const related = products.filter(p => p.slug !== product.slug && p.fragranceFamily === product.fragranceFamily).slice(0, 3);
const backup = products.filter(p => p.slug !== product.slug).slice(0, 3);
const show = related.length >= 2 ? related : backup;

const catLabel: Record<string, string> = {
  candle: 'Candle',
  diffuser: 'Diffuser',
  melt: 'Wax melt',
  body: 'Body',
  gift: 'Gift',
  refill: 'Refill',
};
---
<Base title={`${product.name} — Saltbrush & Co.`} description={product.blurb}>
  <section class="pt-12 pb-20 bg-linen">
    <div class="wrap-wide">
      <nav class="text-xs font-mono uppercase tracking-wider text-stone/60 mb-10">
        <a href={`${base}/shop/`} class="hover:text-clay">Shop</a>
        <span class="mx-2 text-stone/30">/</span>
        <span>{catLabel[product.category]}</span>
        <span class="mx-2 text-stone/30">/</span>
        <span class="text-stone">{product.name}</span>
      </nav>

      <div class="grid md:grid-cols-[1.05fr_1fr] gap-14">
        <div class="relative bg-bone rounded-sharp overflow-hidden">
          <img src={product.image} alt={product.name} class="w-full aspect-[4/5] object-cover" />
          {product.badge && (
            <span class="absolute top-5 left-5 bg-linen text-stone px-3 py-1.5 font-mono uppercase tracking-wider text-[10px] border border-stone/20">{product.badge}</span>
          )}
          <span class="absolute bottom-5 right-5 bg-linen/90 px-3 py-1.5 batch-label border border-stone/20">Batch {product.batch} · {product.fragranceFamily}</span>
        </div>
        <div>
          <p class="eyebrow">{catLabel[product.category]} · {product.fragranceFamily}</p>
          <h1 class="text-stone mb-4">{product.name}</h1>
          <p class="text-stone/70 text-lg italic font-display leading-snug mb-8">{product.blurb}</p>

          <div class="grid grid-cols-3 gap-5 py-6 border-y border-stone/15 mb-10">
            <div>
              <div class="batch-label mb-1">Price</div>
              <div class="font-display text-2xl text-stone">${product.price}</div>
            </div>
            <div>
              <div class="batch-label mb-1">Size</div>
              <div class="font-display text-lg text-stone">{product.size}</div>
            </div>
            {product.burnTime ? (
              <div>
                <div class="batch-label mb-1">Burn</div>
                <div class="font-display text-lg text-stone">{product.burnTime}</div>
              </div>
            ) : (
              <div>
                <div class="batch-label mb-1">Family</div>
                <div class="font-display text-lg text-stone">{product.fragranceFamily}</div>
              </div>
            )}
          </div>

          <p class="text-stone/80 text-base leading-relaxed mb-10 font-light">{product.description}</p>

          <div class="flex items-center gap-4 mb-10">
            <div class="flex items-center border border-stone/30 rounded-sharp">
              <button class="w-11 h-12 text-stone hover:text-clay" aria-label="Decrease quantity">&minus;</button>
              <span class="w-12 text-center font-display text-lg text-stone">1</span>
              <button class="w-11 h-12 text-stone hover:text-clay" aria-label="Increase quantity">+</button>
            </div>
            <button class="btn-primary flex-1">Add to cart &middot; ${product.price}</button>
          </div>

          <dl class="space-y-7 text-sm">
            <div>
              <dt class="batch-label mb-3">Fragrance · Top notes</dt>
              <dd class="flex flex-wrap gap-2">
                {product.topNotes.map(n => <span class="note">{n}</span>)}
              </dd>
            </div>
            <div>
              <dt class="batch-label mb-3">Fragrance · Heart notes</dt>
              <dd class="flex flex-wrap gap-2">
                {product.heartNotes.map(n => <span class="note">{n}</span>)}
              </dd>
            </div>
            <div>
              <dt class="batch-label mb-3">Fragrance · Base notes</dt>
              <dd class="flex flex-wrap gap-2">
                {product.baseNotes.map(n => <span class="note">{n}</span>)}
              </dd>
            </div>
            <div>
              <dt class="batch-label mb-2">Ingredients</dt>
              <dd class="text-stone/75 font-light leading-relaxed">{product.ingredients.join(', ')}.</dd>
            </div>
            <div>
              <dt class="batch-label mb-2">Care &amp; burn</dt>
              <dd class="text-stone/75 font-light leading-relaxed">{product.care}</dd>
            </div>
            <div>
              <dt class="batch-label mb-2">Where it's made</dt>
              <dd class="text-stone/75 font-light leading-relaxed">Hand-poured in Hahndorf, South Australia by Marni and the Saltbrush team. Cured five days before shipping.</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  {show.length > 0 && (
    <section class="py-20 bg-bone">
      <div class="wrap-wide">
        <div class="flex items-end justify-between flex-wrap gap-4 mb-10">
          <h2 class="text-stone">Stay in the family.</h2>
          <a href={`${base}/shop/`} class="font-body uppercase tracking-quiet text-xs font-semibold text-clay hover:text-ochre border-b border-clay pb-1">Back to the shop  &rarr;</a>
        </div>
        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
          {show.map(p => <ProductCard product={p} />)}
        </div>
      </div>
    </section>
  )}
</Base>
