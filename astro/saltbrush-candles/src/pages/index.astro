---
import Base from '../layouts/Base.astro';
import ProductCard from '../components/ProductCard.astro';
import ScentCard from '../components/ScentCard.astro';
import { products } from '../data/products';
import { scents } from '../data/scents';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const featured = products.filter(p => ['saltbrush-after-rain', 'hahndorf-morning', 'ironbark-and-smoke'].includes(p.slug));

const heroImg = 'https://images.unsplash.com/photo-1673822284360-a5b49882019f?w=2000&h=1400&fit=crop&q=80&auto=format';
const founderImg = 'https://images.unsplash.com/photo-1669151432266-cd991ea149ad?w=1200&h=1400&fit=crop&q=80&auto=format';
const refillImg = 'https://images.unsplash.com/photo-1534889156217-d643df14f14a?w=1400&h=900&fit=crop&q=80&auto=format';

const families = [
  { slug: 'Native',  label: 'Native',  copy: 'Saltbrush, wattle, eucalyptus, honey myrtle.', img: 'https://images.unsplash.com/photo-1559599101-f09722fb4948?w=700&h=900&fit=crop&q=80&auto=format' },
  { slug: 'Citrus',  label: 'Citrus',  copy: 'Lemon myrtle, grapefruit peel, verbena.',       img: 'https://images.unsplash.com/photo-1560343090-f0409e92791a?w=700&h=900&fit=crop&q=80&auto=format' },
  { slug: 'Woody',   label: 'Woody',   copy: 'Sandalwood, ironbark, vetiver, leather.',       img: 'https://images.unsplash.com/photo-1513558161293-cdaf765ed2fd?w=700&h=900&fit=crop&q=80&auto=format' },
  { slug: 'Floral',  label: 'Floral',  copy: 'Boronia, pear blossom, elderflower, orris.',    img: 'https://images.unsplash.com/photo-1600857544200-b2f666a9a2ec?w=700&h=900&fit=crop&q=80&auto=format' },
];
---
<Base title="Saltbrush & Co. — Hand-poured candles from the Adelaide Hills">
  {/* HERO — two columns, quiet, domestic */}
  <section class="relative overflow-hidden bg-linen">
    <div class="grid md:grid-cols-[1.05fr_1fr] min-h-[82vh]">
      <div class="flex flex-col justify-center px-8 md:px-16 py-16 md:py-20 max-w-2xl">
        <p class="eyebrow">Batch 047 · Autumn edition · Hahndorf</p>
        <h1 class="text-stone mb-10">
          Slow scents<br/>
          <em class="italic">from the hills.</em>
        </h1>
        <p class="text-stone/75 text-lg md:text-xl leading-relaxed max-w-lg font-light mb-10">
          Hand-poured soy candles, reed diffusers and native botanical scents — made in small batches in Hahndorf, in the Adelaide Hills. Lit slow, burned slowly, smelled deeply.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href={`${base}/shop/`} class="btn-primary">Browse the range</a>
          <a href={`${base}/stockists/`} class="btn-ghost">Find a stockist</a>
        </div>
        <div class="mt-14 pt-8 border-t border-stone/15 grid grid-cols-3 gap-6 max-w-md">
          <div>
            <div class="font-display text-3xl text-stone">7</div>
            <div class="batch-label mt-1">Signature scents</div>
          </div>
          <div>
            <div class="font-display text-3xl text-stone">55<span class="text-base align-top ml-1">hrs</span></div>
            <div class="batch-label mt-1">Median burn time</div>
          </div>
          <div>
            <div class="font-display text-3xl text-stone">100%</div>
            <div class="batch-label mt-1">Australian soy</div>
          </div>
        </div>
      </div>
      <div class="relative min-h-[350px] md:min-h-0">
        <img src={heroImg} alt="A lit Saltbrush candle on a wooden table at dusk" class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute bottom-6 right-6 bg-linen/95 border border-stone/20 px-5 py-4 rounded-sharp max-w-[220px]">
          <div class="batch-label mb-1">Now pouring</div>
          <div class="font-display text-stone text-xl leading-tight">Saltbrush,<br/><em class="italic">after rain.</em></div>
        </div>
      </div>
    </div>
  </section>

  <div class="deckle"></div>

  {/* SIGNATURE SCENT STRIP — 7 across */}
  <section class="py-20 bg-bone">
    <div class="wrap-wide">
      <div class="flex items-end justify-between flex-wrap gap-6 mb-12">
        <div class="max-w-lg">
          <p class="eyebrow">The scent library</p>
          <h2 class="text-stone">Seven <em class="italic">considered</em> scents.</h2>
          <p class="text-stone/70 mt-5 leading-relaxed font-light">
            Each one built in-house and cured for six weeks before a single candle is poured. Arrange them by room, by mood, or — honestly — by what smells like your nicest memory.
          </p>
        </div>
        <a href={`${base}/scents/`} class="font-body uppercase tracking-quiet text-xs font-semibold text-clay hover:text-ochre border-b border-clay pb-1">Explore the library  &rarr;</a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-4">
        {scents.map((s, i) => (
          <a href={`${base}/scents/#${s.slug}`} class="group block">
            <div class="aspect-[3/4] overflow-hidden bg-linen border border-stone/10 rounded-sharp">
              <img src={s.image} alt={s.name} class="w-full h-full object-cover transition duration-700 group-hover:scale-[1.04]" />
            </div>
            <div class="pt-3">
              <div class="batch-label">№ {String(i + 1).padStart(2, '0')} · {s.family}</div>
              <div class="font-display text-stone text-lg leading-tight mt-1 group-hover:text-moss">{s.name}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* FEATURED 3 CANDLES */}
  <section class="py-24 bg-linen">
    <div class="wrap-wide">
      <div class="flex items-end justify-between flex-wrap gap-6 mb-14">
        <div>
          <p class="eyebrow">The batch</p>
          <h2 class="text-stone">Three to try first.</h2>
          <span class="rule-ochre mt-6"></span>
        </div>
        <a href={`${base}/shop/`} class="font-body uppercase tracking-quiet text-xs font-semibold text-clay hover:text-ochre border-b border-clay pb-1">See all products  &rarr;</a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {featured.map(p => <ProductCard product={p} />)}
      </div>
    </div>
  </section>

  {/* FOUNDER STORY BAND */}
  <section class="relative py-28 bg-bone">
    <div class="wrap-wide grid md:grid-cols-[1fr_1.1fr] gap-14 items-center">
      <div class="relative">
        <img src={founderImg} alt="Marni in the Saltbrush studio in Hahndorf" class="w-full aspect-[4/5] object-cover rounded-sharp" />
        <div class="absolute -bottom-5 -right-5 hidden md:block bg-linen border border-stone/20 px-5 py-4 rounded-sharp">
          <div class="batch-label mb-1">The founder</div>
          <div class="font-display text-stone text-xl">Marni Clarke</div>
          <div class="text-xs text-stone/60 font-mono uppercase tracking-wider mt-1">Est. 2019 · Hahndorf</div>
        </div>
      </div>
      <div>
        <p class="eyebrow">Our story</p>
        <h2 class="text-stone mb-6">A studio in a stone cottage, <em class="italic">just off Main Street.</em></h2>
        <p class="text-stone/80 text-lg leading-relaxed mb-5 font-light">
          Saltbrush &amp; Co. started in 2019 at Marni Clarke’s kitchen table, with one pot of melted soy wax and a gut feeling that people wanted scents that behaved like a real place, not a brief.
        </p>
        <p class="text-stone/80 text-lg leading-relaxed mb-8 font-light">
          Five years on, every candle is still hand-poured in the old bluestone cottage on Hahndorf’s Main Street — now with better shelves, better labels, and a deep bench of native Australian fragrances that we’ve taken our sweet time to get right.
        </p>
        <a href={`${base}/about/`} class="btn-ghost">Read the full story</a>
      </div>
    </div>
  </section>

  {/* SCENT FAMILIES */}
  <section class="py-24 bg-linen">
    <div class="wrap-wide">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="eyebrow">Four families</p>
        <h2 class="text-stone mb-5">How we think about scent.</h2>
        <p class="text-stone/70 font-light leading-relaxed">
          Every Saltbrush scent lives in one of four families. It’s a quiet way to help you pick — and a cheat-sheet for layering two together if you want to make your house smell like only your house.
        </p>
      </div>
      <div class="grid md:grid-cols-4 gap-5">
        {families.map(f => (
          <div class="relative aspect-[3/4] overflow-hidden rounded-sharp group">
            <img src={f.img} alt={f.label} class="absolute inset-0 w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-coal/85 via-coal/30 to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 p-6">
              <div class="batch-label !text-linen/70 mb-2">Family</div>
              <div class="font-display text-linen text-3xl mb-2"><em class="italic !text-linen">{f.label}</em></div>
              <p class="text-linen/80 text-sm font-light leading-relaxed">{f.copy}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* REFILL CTA */}
  <section class="relative py-28 overflow-hidden bg-coal">
    <div class="absolute inset-0 opacity-40">
      <img src={refillImg} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-coal via-coal/80 to-coal/30"></div>
    </div>
    <div class="wrap-wide relative">
      <div class="max-w-2xl">
        <p class="font-mono uppercase tracking-wider text-[10px] text-ochre mb-4">// Refill program · Batch 047</p>
        <h2 class="text-linen mb-6">Keep the vessel.<br/><em class="italic text-ochre">Skip the waste.</em></h2>
        <p class="text-linen/80 text-lg leading-relaxed mb-5 font-light">
          Every Saltbrush candle is built to be refilled. Send your empty vessel back (or drop it off in Hahndorf, Stirling or Daylesford) and we’ll gently re-pour it for 30% less than a new candle, with almost no packaging.
        </p>
        <p class="text-linen/80 text-lg leading-relaxed mb-9 font-light">
          We refill any scent into any vessel, even the one with the slightly-too-dark pour. Seven months in and we’ve now re-poured more than 2,400 vessels.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href={`${base}/shop/saltbrush-refill-pouch/`} class="btn-ochre">Get a refill pouch</a>
          <a href={`${base}/about/#refill`} class="inline-flex items-center justify-center gap-2 border border-linen/40 text-linen px-7 py-3 font-body uppercase tracking-quiet text-xs font-semibold rounded-sharp hover:border-linen hover:bg-linen hover:text-stone transition">How it works</a>
        </div>
      </div>
    </div>
  </section>
</Base>
