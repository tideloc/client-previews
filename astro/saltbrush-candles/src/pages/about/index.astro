---
import Base from '../../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const studioImg = 'https://images.unsplash.com/photo-1669151432266-cd991ea149ad?w=1400&h=1600&fit=crop&q=80&auto=format';
const cottageImg = 'https://images.unsplash.com/photo-1604068549290-dea0e4a305ca?w=1400&h=900&fit=crop&q=80&auto=format';
const botanicalImg = 'https://images.unsplash.com/photo-1559599101-f09722fb4948?w=1400&h=900&fit=crop&q=80&auto=format';

const steps = [
  { n: '01', t: 'Source', c: 'Australian-grown essential oils and native botanicals from seven certified growers in SA, NSW and Tasmania. Soy wax from a single Victorian farm cooperative.' },
  { n: '02', t: 'Blend',  c: 'Every fragrance is blended by hand in 40ml test batches before it ever touches a 20L pour. Each scent cures for six weeks before we sign off.' },
  { n: '03', t: 'Pour',   c: 'We pour in batches of 24 vessels at a time, by hand, in Hahndorf. Every candle is numbered by the pourer and the date on the underside of the base.' },
  { n: '04', t: 'Cure',   c: 'Candles cure for five days before shipping. Diffusers for 14 days. It’s slower, and it’s exactly why they burn the way they do.' },
];

const commits = [
  { t: 'Refillable vessels',  c: 'Every candle vessel is designed to be refilled. Around 35% of our customers are now on refill pouches, and we offset the rest.' },
  { t: 'Carbon-neutral ship', c: 'Every Saltbrush order ships carbon-neutral via Sendle. We pay for the offsets — you don’t see it added at checkout.' },
  { t: 'Australian supply',   c: '100% of the wax and more than 90% of the botanicals are Australian. The exceptions are noted on each product page.' },
  { t: 'Minimal packaging',   c: 'Boxes, void-fill and labels are recycled, recyclable and unbleached. No plastic tape. Nothing printed in colour we don’t need.' },
];
---
<Base title="About — Saltbrush & Co." description="The story behind Saltbrush & Co., our founder Marni Clarke, our production process, and the ways we try to make quiet, responsible candles in Hahndorf.">
  <section class="pt-20 pb-14 bg-linen">
    <div class="wrap">
      <p class="eyebrow">About the studio · Hahndorf, SA</p>
      <h1 class="text-stone mb-6">A stone cottage,<br/><em class="italic">seven scents,</em><br/>a very slow pace.</h1>
      <p class="text-stone/70 max-w-2xl text-lg leading-relaxed font-light">
        Saltbrush &amp; Co. is a small candle studio on Hahndorf’s Main Street in the Adelaide Hills. We pour in batches of 24, on the same old bluestone bench Marni bought in 2019, and we’ve never been in a hurry to grow past that.
      </p>
    </div>
  </section>

  {/* Story */}
  <section class="py-20 bg-bone">
    <div class="wrap-wide grid md:grid-cols-[1fr_1.1fr] gap-14 items-center">
      <img src={cottageImg} alt="The Saltbrush studio in a bluestone cottage in Hahndorf" class="w-full aspect-[4/5] object-cover rounded-sharp" />
      <div>
        <p class="eyebrow">The story</p>
        <h2 class="text-stone mb-6">It started with one candle and a tip-off <em class="italic">about a cottage</em>.</h2>
        <p class="text-stone/80 text-lg leading-relaxed mb-5 font-light">
          Marni Clarke spent a decade as a fragrance chemist in Melbourne before moving home to the Adelaide Hills in 2019. She poured her first Saltbrush candle on the kitchen table of a rented house in Verdun with soy wax from a friend of a friend and saltbrush leaves from the paddock behind the shed.
        </p>
        <p class="text-stone/80 text-lg leading-relaxed mb-5 font-light">
          She sold eighteen of them at the Stirling markets the following Sunday, came home with a lot of notes, and spent the next six months refining one recipe. That recipe is now Saltbrush, After Rain — the candle the business is named for and still the one we pour the most.
        </p>
        <p class="text-stone/80 text-lg leading-relaxed font-light">
          In 2021 we took over a small bluestone cottage on Main Street Hahndorf, behind the old bakery. It’s where every candle is still made today.
        </p>
      </div>
    </div>
  </section>

  {/* Founder aside */}
  <section class="py-20 bg-linen">
    <div class="wrap-wide grid md:grid-cols-[1.1fr_0.9fr] gap-14 items-start">
      <div>
        <p class="eyebrow">The founder</p>
        <h2 class="text-stone mb-6">Marni Clarke.</h2>
        <p class="text-stone/80 text-lg leading-relaxed mb-5 font-light">
          Marni trained in fragrance chemistry at RMIT and spent eight years working on house scents for Australian hotels before starting Saltbrush. She grew up in Stirling, lives now with her partner Tom and their kelpie Norman on a block just outside Hahndorf, and — for the avoidance of doubt — still pours every new batch herself.
        </p>
        <p class="text-stone/80 text-lg leading-relaxed mb-8 font-light">
          The Saltbrush team is small, five people, and all locals. We take Mondays off, close for two weeks in January, and don’t do drop-shipping, subscriptions or discount codes. It’s an unfashionable way to run a candle company, and we like it.
        </p>
        <blockquote class="border-l-2 border-ochre pl-6 py-2">
          <p class="font-display italic text-stone text-2xl leading-snug mb-3">&ldquo;The best candle in the house shouldn’t be the loudest. It should be the one you stop noticing after ten minutes — because it just smells <em class="italic text-moss">right</em>.&rdquo;</p>
          <footer class="batch-label">Marni Clarke · Founder</footer>
        </blockquote>
      </div>
      <img src={studioImg} alt="Marni in the Hahndorf studio" class="w-full aspect-[4/5] object-cover rounded-sharp" />
    </div>
  </section>

  <div class="deckle"></div>

  {/* Production process */}
  <section class="py-20 bg-bone">
    <div class="wrap-wide">
      <div class="text-center max-w-xl mx-auto mb-14">
        <p class="eyebrow">Our process</p>
        <h2 class="text-stone mb-4">Four steps.<br/>Nothing clever.</h2>
        <p class="text-stone/70 font-light leading-relaxed">How every Saltbrush candle is made, from paddock to pour.</p>
      </div>
      <div class="grid md:grid-cols-4 gap-5">
        {steps.map(s => (
          <div class="border border-stone/15 bg-linen p-7 rounded-sharp">
            <div class="font-display text-6xl text-ochre leading-none mb-4">{s.n}</div>
            <h3 class="text-stone text-xl mb-3">{s.t}</h3>
            <p class="text-stone/70 text-sm font-light leading-relaxed">{s.c}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Sustainability */}
  <section id="refill" class="py-24 bg-linen">
    <div class="wrap-wide grid md:grid-cols-[1.1fr_1fr] gap-14 items-start">
      <div>
        <p class="eyebrow">Sustainability · Refill program</p>
        <h2 class="text-stone mb-6">What we actually do.</h2>
        <p class="text-stone/70 text-lg leading-relaxed font-light mb-10">
          We’re not going to pretend a candle company is going to save the world, but here are the four specific, checkable things we do — and the one thing we decided not to.
        </p>
        <div class="space-y-6">
          {commits.map(c => (
            <div class="flex gap-5">
              <div class="w-10 h-10 shrink-0 border border-moss text-moss rounded-sharp flex items-center justify-center">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <div>
                <h4 class="font-display text-stone text-xl mb-1">{c.t}</h4>
                <p class="text-stone/70 font-light leading-relaxed">{c.c}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="bg-bone border border-stone/15 p-8 md:p-10 rounded-sharp sticky top-28">
        <div class="batch-label mb-3">The refill program</div>
        <h3 class="text-stone text-2xl mb-4">Refill your Saltbrush.</h3>
        <p class="text-stone/70 font-light leading-relaxed mb-6">
          Send an empty Saltbrush vessel back to us — free if you drop it at the Hahndorf studio, $6 via reply-paid — and we’ll clean it, re-wick it and re-pour it in the scent of your choice. It comes back to you at 30% less than a new candle.
        </p>
        <ul class="space-y-3 text-sm text-stone/80 font-light mb-8">
          <li class="flex gap-3"><span class="text-ochre">·</span> Any Saltbrush scent into any Saltbrush vessel</li>
          <li class="flex gap-3"><span class="text-ochre">·</span> Up to three times per vessel (then we retire it)</li>
          <li class="flex gap-3"><span class="text-ochre">·</span> 7–10 day turnaround from studio arrival</li>
          <li class="flex gap-3"><span class="text-ochre">·</span> 2,400+ vessels refilled to date</li>
        </ul>
        <a href={`${base}/shop/saltbrush-refill-pouch/`} class="btn-ochre w-full">Order a refill pouch</a>
      </div>
    </div>
  </section>

  {/* Closing strip */}
  <section class="relative py-28 overflow-hidden">
    <div class="absolute inset-0">
      <img src={botanicalImg} alt="" class="w-full h-full object-cover opacity-60" />
      <div class="absolute inset-0 bg-gradient-to-r from-linen via-linen/80 to-linen/20"></div>
    </div>
    <div class="wrap-wide relative">
      <div class="max-w-xl">
        <p class="eyebrow">Visit the studio</p>
        <h2 class="text-stone mb-6">We’re open, Friday to Sunday.</h2>
        <p class="text-stone/80 text-lg leading-relaxed mb-8 font-light">
          22a Main Street, Hahndorf. Behind the old bakery. Smell everything, talk to Marni if she’s around, bring your empty vessel. We run a candle-pouring workshop on the first Sunday of every month — bookings via email.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href={`${base}/stockists/`} class="btn-primary">Other stockists</a>
          <a href="mailto:hello@saltbrushandco.com.au" class="btn-ghost">Book the workshop</a>
        </div>
      </div>
    </div>
  </section>
</Base>
