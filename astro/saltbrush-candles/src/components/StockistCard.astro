---
import type { Stockist } from '../data/stockists';
interface Props { stockist: Stockist }
const { stockist } = Astro.props;
const typeLabel: Record<string, string> = {
  retail: 'Retail',
  cafe: 'Café',
  hotel: 'Hotel',
  spa: 'Spa',
};
---
<div class="border border-stone/15 bg-linen p-6 rounded-sharp">
  <div class="flex items-start justify-between gap-3 mb-3">
    <h3 class="font-display text-stone text-xl leading-tight">{stockist.name}</h3>
    <span class="font-mono uppercase tracking-wider text-[9px] text-moss border border-moss/40 px-2 py-1 whitespace-nowrap">{typeLabel[stockist.type]}</span>
  </div>
  <p class="text-stone/70 text-sm font-light">{stockist.suburb}, {stockist.state}</p>
  {stockist.note && (
    <p class="batch-label mt-3 pt-3 border-t border-stone/10">{stockist.note}</p>
  )}
</div>
