---
import type { Product } from '../data/products';
interface Props { product: Product }
const { product } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const catLabel: Record<string, string> = {
  candle: 'Candle',
  diffuser: 'Diffuser',
  melt: 'Wax Melt',
  body: 'Body',
  gift: 'Gift',
  refill: 'Refill',
};
---
<a href={`${base}/shop/${product.slug}/`} class="group block bg-linen border border-stone/10 rounded-sharp overflow-hidden transition hover:border-ochre/50">
  <div class="relative aspect-[4/5] overflow-hidden bg-bone">
    <img src={product.image} alt={product.name} class="w-full h-full object-cover transition duration-700 group-hover:scale-[1.03]" />
    {product.badge && (
      <span class="absolute top-4 left-4 bg-linen text-stone px-3 py-1 font-mono uppercase tracking-wider text-[10px] border border-stone/20">{product.badge}</span>
    )}
    <span class="absolute bottom-3 right-3 batch-label bg-linen/90 px-2 py-1">Batch {product.batch}</span>
  </div>
  <div class="p-6">
    <p class="eyebrow !mb-2">{catLabel[product.category]} · {product.size}</p>
    <div class="flex items-baseline justify-between gap-3 mb-3">
      <h3 class="font-display text-stone text-2xl leading-tight group-hover:text-clay transition">{product.name}</h3>
      <span class="font-mono text-sm text-stone whitespace-nowrap">${product.price}</span>
    </div>
    <p class="text-stone/70 text-sm leading-relaxed font-light">{product.blurb}</p>
    {product.burnTime && (
      <p class="batch-label mt-4 pt-3 border-t border-stone/10">Burn · {product.burnTime}</p>
    )}
  </div>
</a>
