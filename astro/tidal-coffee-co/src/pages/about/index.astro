---
import Base from '../../layouts/Base.astro';
import { team } from '../../data/team';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const heroImg     = 'https://images.unsplash.com/photo-1521017432531-fbd92d768814?w=2000&h=1400&fit=crop&q=80&auto=format';
const roasteryImg = 'https://images.unsplash.com/photo-1529892485617-25f63cd7b1e9?w=1400&h=1000&fit=crop&q=80&auto=format';
const beansImg    = 'https://images.unsplash.com/photo-1509785307050-d4066910ec1e?w=1400&h=1000&fit=crop&q=80&auto=format';
const cuppingImg  = 'https://images.unsplash.com/photo-1610889556528-9a770e32642f?w=1400&h=1000&fit=crop&q=80&auto=format';

const milestones = [
  { y: '2016', t: 'First cart at Thirroul Seaside Festival.' },
  { y: '2018', t: 'Cafe opens at 247 Lawrence Hargrave Drive.' },
  { y: '2019', t: '12kg Probat commissioned; Marcus joins as head roaster.' },
  { y: '2021', t: 'First direct-trade relationship with Finca La Palma.' },
  { y: '2023', t: 'Australian Specialty Coffee Awards — silver medal, filter category.' },
  { y: '2025', t: 'Bought our first microlot at auction. Still recovering from the freight bill.' },
];

const awards = [
  { year: '2024', body: "AICA Chain of Custody — Bronze (Single Origin, Ethiopia)" },
  { year: '2023', body: "ASCA National — Silver (Filter, Colombia El Paraíso)" },
  { year: '2023', body: "Golden Bean — Bronze (Milk-based, Escarpment Blend)" },
  { year: '2021', body: "Hunter Region Coffee Awards — Gold (Espresso Blend)" },
];
---
<Base title="About — Tidal Coffee Co.">
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img src={heroImg} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-br from-surf/90 via-surf/80 to-deep/80"></div>
    </div>
    <div class="wrap relative py-24 md:py-36 text-shell">
      <p class="font-mono text-[10px] uppercase tracking-rule text-brass mb-8">Since 2016</p>
      <h1 class="font-display italic text-shell text-5xl md:text-7xl leading-[0.95] mb-8 max-w-4xl">
        A small roastery on<br/>the NSW South Coast.
      </h1>
      <p class="text-shell/85 text-lg md:text-xl leading-relaxed max-w-2xl">
        We didn't plan to open a roastery. We wanted to open a cafe that served coffee we liked. Turns out no one was roasting it the way we wanted, so we learned how. Ten years later we're still small, still in Thirroul, still roasting three times a week.
      </p>
    </div>
  </section>

  {/* Story */}
  <section class="py-24">
    <div class="wrap grid md:grid-cols-12 gap-12 items-start">
      <div class="md:col-span-5 md:sticky md:top-28">
        <img src={roasteryImg} alt="Our roaster" class="w-full aspect-[4/5] object-cover rounded-[3px] border border-surf/10" />
      </div>
      <div class="md:col-span-7">
        <p class="eyebrow">The story</p>
        <h2 class="font-display italic text-4xl md:text-5xl text-surf leading-tight mb-8">Start with a cafe.<br/>End up a roastery.</h2>
        <div class="space-y-5 text-surf/85 text-lg leading-relaxed">
          <p>Elena opened the first Tidal cart at the Thirroul Seaside & Arts Festival in March 2016 — a borrowed single-group La Marzocco, a pop-up tent, and forty kilos of borrowed beans from a Sydney roaster. By the end of the weekend they'd sold out and Elena had a spreadsheet full of regulars asking when the permanent shop opened.</p>
          <p>It took two years. In late 2018 we took over a narrow shopfront on Lawrence Hargrave Drive, between the bakery and the old bookshop. For the first eighteen months we bought beans from three different Sydney roasters, trying to find coffee that tasted the way we remembered it tasting in cafes overseas. None of them quite did.</p>
          <p>In 2019 we rented a 1kg sample roaster and started teaching ourselves. Marcus came on that same year — he'd been roasting in Melbourne for five years and was looking for somewhere smaller. We commissioned the 12kg Probat eighteen months later. Every bean we sell now comes off that machine.</p>
          <p>We've stayed small on purpose. One cafe. Three roast days. No fleet of trucks, no second site on the Gong. If we're ever tempted, Marcus reminds us we already have enough work.</p>
        </div>
      </div>
    </div>
  </section>

  {/* Timeline */}
  <section class="py-20 bg-shell">
    <div class="wrap">
      <div class="max-w-xl mb-12">
        <p class="eyebrow">A short timeline</p>
        <h2 class="font-display italic text-4xl md:text-5xl text-surf leading-tight">Ten years, roughly.</h2>
      </div>
      <ol class="space-y-8 border-l border-brass/40 pl-8 max-w-3xl">
        {milestones.map(m => (
          <li class="relative">
            <span class="absolute -left-10 top-1 w-3 h-3 rounded-full bg-brass border-4 border-shell"></span>
            <p class="font-mono text-xs uppercase tracking-rule text-brass mb-1">{m.y}</p>
            <p class="font-display italic text-2xl text-surf leading-snug">{m.t}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  {/* Sourcing */}
  <section class="py-24 bg-deep text-shell">
    <div class="wrap grid md:grid-cols-12 gap-12 items-center">
      <div class="md:col-span-6">
        <p class="font-mono text-[10px] uppercase tracking-rule text-brass mb-4">How we source</p>
        <h2 class="font-display italic text-shell text-4xl md:text-5xl leading-tight mb-6">Direct Trade,<br/>not Fair Trade.</h2>
        <div class="space-y-5 text-shell/80 leading-relaxed">
          <p>Fair Trade pays farmers a minimum — it's a floor. Direct Trade starts from a different question: what is this coffee actually worth, and who gets paid what share of it?</p>
          <p>We buy through three importer partners we've worked with for seven years — Melbourne Coffee Merchants, Cofinet, and Caravela. They give us farm-level transparency: we know the name of the farm, the name of the producer, what they were paid, and (usually) how that compares to the C-market price that week.</p>
          <p>Where we can, we visit. Elena's been to Finca La Palma in Tolima three times. Marcus spent a month in Rwanda in 2022 cupping with three co-operatives. It's not a marketing line; it's just how you build trust with people you're asking to farm at a standard most farmers aren't asked to hit.</p>
          <p>We pay, on average, 68% above the C-market benchmark for the green coffee we buy. It's not a badge we shout about. It's just the cost of roasting coffee we want to drink.</p>
        </div>
      </div>
      <div class="md:col-span-6">
        <img src={beansImg} alt="Green coffee beans" class="w-full aspect-[4/5] object-cover rounded-[3px]" />
      </div>
    </div>
  </section>

  {/* Team */}
  <section class="py-24">
    <div class="wrap">
      <div class="max-w-xl mb-14">
        <p class="eyebrow">The team</p>
        <h2 class="font-display italic text-4xl md:text-5xl text-surf leading-tight">Two of us, mostly.</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-10">
        {team.map(m => (
          <article class="chart-frame overflow-hidden">
            <img src={m.image} alt={m.name} class="w-full aspect-[4/5] object-cover" />
            <div class="p-8">
              <p class="font-mono text-[10px] uppercase tracking-rule text-brass mb-2">{m.role}</p>
              <h3 class="font-display italic text-3xl text-surf mb-4">{m.name}</h3>
              <p class="text-surf/75 leading-relaxed">{m.bio}</p>
            </div>
          </article>
        ))}
      </div>
      <p class="font-mono text-[10px] uppercase tracking-rule text-tide mt-10 text-center">Plus Tess, Jack, and Nina behind the bar most mornings.</p>
    </div>
  </section>

  {/* Awards */}
  <section class="py-24 bg-shell">
    <div class="wrap grid md:grid-cols-12 gap-12 items-start">
      <div class="md:col-span-5">
        <p class="eyebrow">Awards & recognition</p>
        <h2 class="font-display italic text-4xl md:text-5xl text-surf leading-tight mb-6">A few things<br/>on the shelf.</h2>
        <p class="text-surf/70 leading-relaxed">We enter the big Australian competitions most years — not because it matters, but because the blind-cupping feedback is the cheapest quality-control check we can get.</p>
      </div>
      <div class="md:col-span-7">
        <ul class="divide-y divide-surf/10 border-t border-b border-surf/10">
          {awards.map(a => (
            <li class="py-5 flex items-baseline gap-6">
              <span class="font-mono text-sm text-brass w-14 shrink-0">{a.year}</span>
              <span class="font-display italic text-xl text-surf">{a.body}</span>
            </li>
          ))}
        </ul>
        <img src={cuppingImg} alt="Cupping table" class="w-full aspect-[16/9] object-cover rounded-[3px] border border-surf/10 mt-10" />
      </div>
    </div>
  </section>

  {/* Wholesale */}
  <section id="wholesale" class="py-24 bg-surf text-shell scroll-mt-28">
    <div class="wrap grid md:grid-cols-12 gap-10 items-start">
      <div class="md:col-span-6">
        <p class="font-mono text-[10px] uppercase tracking-rule text-brass mb-4">Wholesale</p>
        <h2 class="font-display italic text-shell text-4xl md:text-5xl leading-tight mb-6">For cafes, offices,<br/>good restaurants.</h2>
        <p class="text-shell/80 leading-relaxed mb-5">We supply a small number of wholesale accounts across the Illawarra and greater Sydney — cafes, offices, and a couple of hotels. Minimum order is 2kg / week; we don't charge account fees, training, or equipment-loan stings. If we can't help dial in your grinder, we don't take you on.</p>
        <a href="mailto:wholesale@tidalcoffee.co" class="inline-flex items-center justify-center gap-2 bg-brass text-shell px-6 py-3 font-body font-medium tracking-chart uppercase text-xs rounded-[3px] hover:bg-copper transition">wholesale@tidalcoffee.co</a>
      </div>
      <div class="md:col-span-6 border border-shell/20 rounded-[3px] p-8">
        <p class="font-mono text-[10px] uppercase tracking-rule text-brass mb-6">What's included</p>
        <ul class="space-y-4 text-shell/85">
          {[
            'Weekly roast, delivered Thursdays (Sydney metro) or shipped overnight',
            'One free dial-in visit per month for the first three months',
            'Training day for new baristas at the Thirroul cafe',
            'Transparent wholesale pricing — no lock-in contract',
            'Dedicated account contact (Elena), not a call centre',
          ].map(item => (
            <li class="flex gap-4 pb-4 border-b border-shell/10 last:border-b-0 last:pb-0">
              <span class="font-mono text-brass text-xs">◆</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</Base>
