---
import type { Entry } from '../data/journal';
interface Props { entry: Entry; size?: 'sm' | 'md' | 'lg'; }
const { entry, size = 'md' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const aspect = size === 'lg' ? 'aspect-[16/10]' : size === 'sm' ? 'aspect-[5/4]' : 'aspect-[4/3]';
const titleSize = size === 'lg' ? 'text-3xl md:text-4xl' : size === 'sm' ? 'text-xl' : 'text-2xl md:text-[1.7rem]';
---
<a href={`${base}/journal/#${entry.slug}`} class="group block">
  <div class="overflow-hidden bg-mist mb-5">
    <img src={entry.image} alt={entry.title} class={`w-full ${aspect} object-cover transition-transform duration-[900ms] ease-out group-hover:scale-[1.03]`} />
  </div>
  <div class="flex items-center gap-4 mb-3">
    <span class="font-mono text-[10px] uppercase tracking-caps text-water">{entry.tag}</span>
    <span class="font-mono text-[10px] uppercase tracking-caps text-stone">{entry.date}</span>
    <span class="font-mono text-[10px] uppercase tracking-caps text-stone">{entry.readTime}</span>
  </div>
  <h3 class={`font-display ${titleSize} text-ink leading-tight group-hover:text-water mb-2`}>{entry.title}</h3>
  {entry.subtitle && <p class="font-display italic text-lead text-base md:text-lg leading-snug mb-3">{entry.subtitle}</p>}
  <p class="text-lead text-sm leading-relaxed">{entry.excerpt}</p>
  <p class="font-mono text-[10px] uppercase tracking-caps text-stone mt-4">By {entry.author}</p>
</a>
