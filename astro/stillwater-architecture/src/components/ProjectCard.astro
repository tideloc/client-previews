---
import type { Project } from '../data/projects';
interface Props {
  project: Project;
  index?: number;
  variant?: 'default' | 'compact' | 'feature';
}
const { project, index, variant = 'default' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = `${base}/projects/${project.slug}/`;

const aspect = variant === 'feature' ? 'aspect-[4/5]' : variant === 'compact' ? 'aspect-[4/3]' : 'aspect-[3/4]';
---
<a href={href} class="group block">
  <figure class="relative overflow-hidden bg-mist">
    <img src={project.heroImage} alt={`${project.name}, ${project.location}`} class={`w-full ${aspect} object-cover transition-transform duration-[900ms] ease-out group-hover:scale-[1.03]`} />
    {typeof index === 'number' && (
      <span class="absolute top-5 left-5 font-mono text-[10px] uppercase tracking-caps text-paper/90">№ {String(index + 1).padStart(2, '0')}</span>
    )}
    {project.status !== 'complete' && (
      <span class="absolute top-5 right-5 font-mono text-[10px] uppercase tracking-caps bg-paper/95 text-ink px-2.5 py-1">
        {project.status === 'in-progress' ? 'In progress' : 'On hold'}
      </span>
    )}
  </figure>
  <figcaption class="pt-6 flex items-start justify-between gap-4">
    <div>
      <p class="loc-tag mb-2">{project.location} · {project.region}</p>
      <h3 class="font-display text-2xl md:text-3xl text-ink leading-tight group-hover:text-water">{project.name}</h3>
      <p class="text-lead text-sm leading-relaxed mt-3 max-w-md">{project.brief}</p>
    </div>
    <div class="text-right shrink-0 pt-1">
      <div class="page-num">{project.year}</div>
      <div class="page-num mt-1.5">{project.type}</div>
    </div>
  </figcaption>
</a>
