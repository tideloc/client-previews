---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { projects } from '../../data/projects';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const years = [...new Set(projects.map(p => p.year))].sort((a, b) => b - a);
---
<Base
  title="Projects — Stillwater Architecture"
  description="A selected portfolio of ten residential and rural projects from Stillwater Architecture, 2022–2026."
>
  {/* ——————————————————————————— MASTHEAD ——————————————————————————— */}
  <section class="pt-16 md:pt-28 pb-12 md:pb-20">
    <div class="wrap grid md:grid-cols-12 gap-10 items-end">
      <div class="md:col-span-7">
        <p class="eyebrow mb-8">Folio · 2022 → 2026</p>
        <h1 class="display-xl max-w-[15ch]">Selected <em class="italic">projects.</em></h1>
      </div>
      <div class="md:col-span-5 md:col-rule">
        <p class="lede max-w-md">
          Ten projects spanning coastal houses, rural masterplans and heritage additions. Each is led by one partner through every phase; none is published before occupancy and first winter.
        </p>
      </div>
    </div>
  </section>

  <div class="rule"></div>

  {/* ——————————————————————————— FILTERS ——————————————————————————— */}
  <section class="py-10 border-b border-ink/10 bg-paper sticky top-[76px] z-30 backdrop-blur">
    <div class="wrap flex flex-wrap items-center gap-x-10 gap-y-4 font-mono text-[11px] uppercase tracking-caps">
      <div class="flex items-center gap-3">
        <span class="text-stone">Type</span>
        <button data-filter="type" data-value="all" class="filter-btn text-ink border-b border-ink pb-0.5">All</button>
        <button data-filter="type" data-value="house" class="filter-btn text-lead hover:text-ink">House</button>
        <button data-filter="type" data-value="addition" class="filter-btn text-lead hover:text-ink">Addition</button>
        <button data-filter="type" data-value="masterplan" class="filter-btn text-lead hover:text-ink">Masterplan</button>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-stone">Place</span>
        <button data-filter="region" data-value="all" class="filter-btn text-ink border-b border-ink pb-0.5">All</button>
        <button data-filter="region" data-value="coast" class="filter-btn text-lead hover:text-ink">Coast</button>
        <button data-filter="region" data-value="rural" class="filter-btn text-lead hover:text-ink">Rural</button>
        <button data-filter="region" data-value="urban" class="filter-btn text-lead hover:text-ink">Urban</button>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-stone">Year</span>
        <button data-filter="year" data-value="all" class="filter-btn text-ink border-b border-ink pb-0.5">All</button>
        {years.map(y => (
          <button data-filter="year" data-value={String(y)} class="filter-btn text-lead hover:text-ink">{y}</button>
        ))}
      </div>
    </div>
  </section>

  {/* ——————————————————————————— GRID ——————————————————————————— */}
  <section class="py-20 md:py-28">
    <div class="wrap">
      <div id="projectsGrid" class="grid md:grid-cols-2 gap-x-10 gap-y-20 md:gap-y-28">
        {projects.map((p, i) => (
          <article class="project-tile" data-type={p.type} data-region={p.region} data-year={p.year}>
            <ProjectCard project={p} index={i} />
          </article>
        ))}
      </div>
      <p id="noResults" class="hidden text-center text-lead text-lg font-display italic mt-20">
        No projects match that combination. Try widening your search.
      </p>
    </div>
  </section>

  <section class="bg-mist py-24">
    <div class="wrap-narrow text-center">
      <p class="eyebrow mb-6">Closing note</p>
      <p class="pull">
        We publish every project here. We don't publish until it has been lived in for at least one winter.
      </p>
    </div>
  </section>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const tiles = document.querySelectorAll<HTMLElement>('.project-tile');
    const noRes = document.getElementById('noResults');
    const state: Record<string, string> = { type: 'all', region: 'all', year: 'all' };

    function apply() {
      let visible = 0;
      tiles.forEach(t => {
        const match =
          (state.type === 'all' || t.dataset.type === state.type) &&
          (state.region === 'all' || t.dataset.region === state.region) &&
          (state.year === 'all' || t.dataset.year === state.year);
        t.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      noRes?.classList.toggle('hidden', visible !== 0);
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.filter!;
        state[key] = btn.dataset.value!;
        buttons.forEach(b => {
          if (b.dataset.filter === key) {
            const active = b.dataset.value === state[key];
            b.classList.toggle('text-ink', active);
            b.classList.toggle('border-b', active);
            b.classList.toggle('border-ink', active);
            b.classList.toggle('pb-0.5', active);
            b.classList.toggle('text-lead', !active);
          }
        });
        apply();
      });
    });
  </script>
</Base>
