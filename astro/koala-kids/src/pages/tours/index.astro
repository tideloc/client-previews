---
import Base from '../../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const expect = [
  { n: '01', title: 'A proper welcome', body: 'Harriet or Liam meets you at reception with a cup of tea. We want to know you and your child before we walk into any room.' },
  { n: '02', title: 'All five rooms', body: 'We walk through each room in age order. You\'ll see the program in action and meet the lead educator on duty.' },
  { n: '03', title: 'The garden & bush kinder site', body: 'Weather permitting, we finish in the garden. Bush kinder site is a short drive — we\'ll show you photos if you can\'t come to us.' },
  { n: '04', title: 'Your questions, not our pitch', body: 'The second half is yours. We answer anything. We also give you a one-page summary of fees for your specific days.' },
];

const faq = [
  { q: 'Can I bring my child?', a: 'Please do. Seeing your child in the environment is half the point. We build the tour around their pace.' },
  { q: 'Can partners attend?', a: 'Absolutely. We encourage both carers to visit, whenever it works for you.' },
  { q: 'How long does a tour take?', a: 'Around 40 minutes. Longer if you have questions — we never rush.' },
  { q: 'What if I can\'t make a tour time?', a: 'Call us. We occasionally run Monday-evening tours for shift-working parents.' },
  { q: 'Do you do virtual tours?', a: 'Yes — by appointment, conducted by Harriet over video call. Not a pre-recorded walkthrough.' },
];
---
<Base title="Book a Tour — Koala Kids Early Learning" description="Tours run Tuesdays and Thursdays at 10am, and Saturdays at 9am. Forty minutes, no sales pitch.">
  <section class="pt-16 pb-10">
    <div class="wrap max-w-3xl">
      <p class="eyebrow">Book a tour</p>
      <h1 class="text-5xl md:text-6xl leading-[1.02] mb-6">Come and see us.</h1>
      <p class="text-earth/80 text-lg leading-relaxed">
        The best way to decide is to stand in the rooms, hear the noise, and watch how educators speak to children. Tours are hosted by Harriet (director) or Liam (assistant director) — never by a salesperson.
      </p>
    </div>
  </section>

  {/* Tour times */}
  <section class="py-12">
    <div class="wrap">
      <div class="grid md:grid-cols-3 gap-6">
        <div class="soft-card text-center">
          <div class="font-mono uppercase text-[10px] tracking-soft text-terracotta mb-3">// Weekday</div>
          <div class="font-display text-2xl text-softcoal mb-2">Tuesdays</div>
          <div class="font-display text-4xl text-eucalypt">10:00am</div>
          <p class="text-earth/70 text-sm mt-4">See the program at its busiest, mid-morning.</p>
        </div>
        <div class="soft-card text-center border-2 border-eucalypt">
          <div class="font-mono uppercase text-[10px] tracking-soft text-terracotta mb-3">// Weekday</div>
          <div class="font-display text-2xl text-softcoal mb-2">Thursdays</div>
          <div class="font-display text-4xl text-eucalypt">10:00am</div>
          <p class="text-earth/70 text-sm mt-4">Bush kinder day — you\'ll see the 3-5 cohort gearing up.</p>
        </div>
        <div class="soft-card text-center">
          <div class="font-mono uppercase text-[10px] tracking-soft text-terracotta mb-3">// Weekend</div>
          <div class="font-display text-2xl text-softcoal mb-2">Saturdays</div>
          <div class="font-display text-4xl text-eucalypt">9:00am</div>
          <p class="text-earth/70 text-sm mt-4">Empty centre, unhurried chat. Good for shift-workers.</p>
        </div>
      </div>
    </div>
  </section>

  {/* What to expect */}
  <section class="py-20 bg-sandstone/50">
    <div class="wrap">
      <p class="eyebrow">What to expect</p>
      <h2 class="text-3xl md:text-4xl mb-10 max-w-2xl">Forty minutes, four beats.</h2>
      <ol class="grid md:grid-cols-2 gap-5">
        {expect.map(e => (
          <li class="card">
            <div class="font-mono text-terracotta text-xl mb-3">{e.n}</div>
            <h3 class="font-display text-xl text-softcoal mb-2">{e.title}</h3>
            <p class="text-earth/80 text-sm leading-relaxed">{e.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  {/* Form */}
  <section class="py-20">
    <div class="wrap grid md:grid-cols-5 gap-12">
      <div class="md:col-span-2">
        <p class="eyebrow">Request a time</p>
        <h2 class="text-3xl md:text-4xl mb-5">Quick form.</h2>
        <p class="text-earth/80 leading-relaxed mb-6">We\'ll confirm your booking within one business day. For urgent enrolments call Harriet on <a href="tel:0249291010" class="text-eucalypt underline">(02) 4929 1010</a>.</p>
        <p class="font-mono uppercase text-[10px] tracking-soft text-earth/55">// No spam. Your details are used to confirm and never shared.</p>
      </div>
      <form class="md:col-span-3 soft-card space-y-5">
        <div class="grid md:grid-cols-2 gap-5">
          <label class="block">
            <span class="font-mono uppercase text-[10px] tracking-soft text-earth/70 mb-2 block">Your name</span>
            <input type="text" name="name" required class="w-full border border-paperbark rounded-card px-4 py-3 bg-cream focus:outline-none focus:border-eucalypt" />
          </label>
          <label class="block">
            <span class="font-mono uppercase text-[10px] tracking-soft text-earth/70 mb-2 block">Phone</span>
            <input type="tel" name="phone" required class="w-full border border-paperbark rounded-card px-4 py-3 bg-cream focus:outline-none focus:border-eucalypt" />
          </label>
        </div>
        <label class="block">
          <span class="font-mono uppercase text-[10px] tracking-soft text-earth/70 mb-2 block">Email</span>
          <input type="email" name="email" required class="w-full border border-paperbark rounded-card px-4 py-3 bg-cream focus:outline-none focus:border-eucalypt" />
        </label>
        <div class="grid md:grid-cols-2 gap-5">
          <label class="block">
            <span class="font-mono uppercase text-[10px] tracking-soft text-earth/70 mb-2 block">Child\'s age</span>
            <select name="age" class="w-full border border-paperbark rounded-card px-4 py-3 bg-cream focus:outline-none focus:border-eucalypt">
              <option>Under 1</option><option>1–2</option><option>2–3</option><option>3–4</option><option>4–5</option><option>Expecting</option>
            </select>
          </label>
          <label class="block">
            <span class="font-mono uppercase text-[10px] tracking-soft text-earth/70 mb-2 block">Preferred tour</span>
            <select name="tour" class="w-full border border-paperbark rounded-card px-4 py-3 bg-cream focus:outline-none focus:border-eucalypt">
              <option>Tuesday 10:00am</option><option>Thursday 10:00am</option><option>Saturday 9:00am</option><option>Virtual tour</option>
            </select>
          </label>
        </div>
        <label class="block">
          <span class="font-mono uppercase text-[10px] tracking-soft text-earth/70 mb-2 block">Anything we should know?</span>
          <textarea name="note" rows="4" class="w-full border border-paperbark rounded-card px-4 py-3 bg-cream focus:outline-none focus:border-eucalypt"></textarea>
        </label>
        <button type="submit" class="btn-primary w-full">Request tour</button>
      </form>
    </div>
  </section>

  {/* FAQ */}
  <section class="py-20 bg-paperbark/40">
    <div class="wrap max-w-3xl">
      <p class="eyebrow">Tour FAQ</p>
      <h2 class="text-3xl md:text-4xl mb-10">Before you come.</h2>
      <dl class="space-y-5">
        {faq.map(f => (
          <div class="card">
            <dt class="font-display text-lg text-softcoal mb-2">{f.q}</dt>
            <dd class="text-earth/80 leading-relaxed">{f.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>
</Base>
