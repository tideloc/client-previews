---
import Base from '../../layouts/Base.astro';
import { menuWeek } from '../../data/menuWeek';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const outdoorImg = 'https://images.unsplash.com/photo-1491156855053-9cdff72c7f85?w=1400&h=1000&fit=crop&q=80&auto=format';
const natureImg = 'https://images.unsplash.com/photo-1577058267193-a82f9d5a46ea?w=1200&h=900&fit=crop&q=80&auto=format';
const kitchenImg = 'https://images.unsplash.com/photo-1438039548937-4b9e8a59c8b1?w=1200&h=900&fit=crop&q=80&auto=format';
---
<Base title="Our Approach — Koala Kids Early Learning" description="Outdoor-led pedagogy, Indigenous perspectives consulted by a Worimi elder, and a full nutrition program cooked fresh daily.">
  <section class="pt-16 pb-10">
    <div class="wrap max-w-3xl">
      <p class="eyebrow">Our approach</p>
      <h1 class="text-5xl md:text-6xl leading-[1.02] mb-6">A pedagogy that takes children seriously.</h1>
      <p class="text-earth/80 text-lg leading-relaxed">
        We are Reggio-inspired, outdoor-led, and grounded in the Early Years Learning Framework. But our real pedagogy is simpler than any label: we pay close attention to children, and we design the day around what we notice.
      </p>
    </div>
  </section>

  {/* Outdoor-led */}
  <section class="py-16">
    <div class="wrap grid md:grid-cols-2 gap-14 items-center">
      <div class="relative order-2 md:order-1">
        <div class="bg-eucalypt/15 rounded-card overflow-hidden">
          <img src={outdoorImg} alt="Children exploring a bushland reserve" class="w-full aspect-[4/3] object-cover mix-blend-multiply" />
        </div>
      </div>
      <div class="order-1 md:order-2">
        <p class="eyebrow">01 · Outdoor-led</p>
        <h2 class="text-3xl md:text-4xl mb-5">We\'re outside, even when it\'s raining.</h2>
        <p class="text-earth/85 text-lg leading-relaxed mb-4">
          Every room spends at least three hours a day outdoors — in our garden, or on a bush walk. The Kookaburra and Wallaby rooms head to our bush kinder site at the nearby Hunter reserve twice a week, led by Liam, our qualified outdoor educator and former parks ranger.
        </p>
        <p class="text-earth/85 text-lg leading-relaxed">
          Bush kinder isn\'t a session. It\'s where the program lives. Children learn to balance, negotiate risk, identify local plants, build with found materials, and — with slight apology to parents — get genuinely, usefully muddy.
        </p>
      </div>
    </div>
  </section>

  {/* Indigenous perspectives */}
  <section class="py-20 bg-sandstone/50">
    <div class="wrap grid md:grid-cols-2 gap-14 items-center">
      <div>
        <p class="eyebrow">02 · Indigenous perspectives</p>
        <h2 class="text-3xl md:text-4xl mb-5">Embedded, not performed.</h2>
        <p class="text-earth/85 text-lg leading-relaxed mb-4">
          Our Indigenous perspectives program is designed in consultation with Aunty Deanne Binge, a Worimi elder who visits monthly and reviews every unit of inquiry we build.
        </p>
        <p class="text-earth/85 text-lg leading-relaxed mb-4">
          We don\'t do one-off NAIDOC crafts. We learn seasonal Awabakal language words, follow seasonal food calendars, and plan our outdoor curriculum around the six seasons of Awabakal country. Our morning acknowledgement is spoken by the children, in their own words, and it changes every term.
        </p>
        <p class="text-earth/85 text-lg leading-relaxed">
          We pay Aunty Deanne for her time. Always.
        </p>
      </div>
      <div class="relative">
        <div class="bg-terracotta/20 rounded-card overflow-hidden">
          <img src={natureImg} alt="Natural materials arranged for exploration" class="w-full aspect-[4/3] object-cover mix-blend-multiply" />
        </div>
      </div>
    </div>
  </section>

  {/* Nutrition */}
  <section id="menu" class="py-20">
    <div class="wrap">
      <div class="grid md:grid-cols-2 gap-14 items-start mb-14">
        <div>
          <p class="eyebrow">03 · Nutrition</p>
          <h2 class="text-3xl md:text-4xl mb-5">One cook. One kitchen. Real food.</h2>
          <p class="text-earth/85 text-lg leading-relaxed mb-4">
            Priya runs our kitchen solo and has done for five years. Every meal is cooked from scratch on site, using the Vic Kids menu framework and a weekly shop from the Newcastle farmer\'s market.
          </p>
          <p class="text-earth/85 text-lg leading-relaxed">
            No heat-and-serve. No reheated pouches. Allergies and cultural diets are catered individually — we currently manage 14 distinct dietary plans and have never crossed a line.
          </p>
        </div>
        <div class="relative">
          <div class="bg-pollen/25 rounded-card overflow-hidden">
            <img src={kitchenImg} alt="Fresh produce ready to be prepared" class="w-full aspect-[4/3] object-cover mix-blend-multiply" />
          </div>
        </div>
      </div>

      <div class="soft-card">
        <p class="font-mono uppercase text-[10px] tracking-soft text-terracotta mb-6">// This week\'s menu</p>
        <div class="grid md:grid-cols-5 gap-5">
          {menuWeek.map(d => (
            <div>
              <h3 class="font-display text-lg text-softcoal mb-3 pb-2 border-b border-earth/15">{d.day}</h3>
              <dl class="space-y-3 text-sm">
                <div>
                  <dt class="font-mono text-[10px] uppercase tracking-soft text-earth/60">Morning tea</dt>
                  <dd class="text-earth/85">{d.morningTea}</dd>
                </div>
                <div>
                  <dt class="font-mono text-[10px] uppercase tracking-soft text-earth/60">Lunch</dt>
                  <dd class="text-earth/85">{d.lunch}</dd>
                </div>
                <div>
                  <dt class="font-mono text-[10px] uppercase tracking-soft text-earth/60">Afternoon tea</dt>
                  <dd class="text-earth/85">{d.afternoonTea}</dd>
                </div>
              </dl>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* Sustainability */}
  <section class="py-20 bg-eucalypt text-cream">
    <div class="wrap">
      <p class="font-mono uppercase text-[10px] tracking-soft text-pollen mb-4">// 04 · Sustainability</p>
      <h2 class="text-cream text-3xl md:text-4xl mb-10 max-w-2xl">Practical, not performative.</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="border border-cream/20 rounded-card p-7">
          <div class="font-display text-3xl text-pollen mb-3">92%</div>
          <p class="text-cream/85 text-sm leading-relaxed">Of our waste is diverted from landfill through composting and recycling.</p>
        </div>
        <div class="border border-cream/20 rounded-card p-7">
          <div class="font-display text-3xl text-pollen mb-3">0kg</div>
          <p class="text-cream/85 text-sm leading-relaxed">Food waste to landfill. All scraps feed the worm farm and garden.</p>
        </div>
        <div class="border border-cream/20 rounded-card p-7">
          <div class="font-display text-3xl text-pollen mb-3">28</div>
          <p class="text-cream/85 text-sm leading-relaxed">Native plants in the edible garden, cared for by the Possum Room.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24">
    <div class="wrap text-center max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl mb-5">Want to see it in practice?</h2>
      <p class="text-earth/80 text-lg mb-8">Our tours are designed to let you see the program mid-morning, at its busiest and best.</p>
      <a href={`${base}/tours/`} class="btn-primary">Book a tour</a>
    </div>
  </section>
</Base>
