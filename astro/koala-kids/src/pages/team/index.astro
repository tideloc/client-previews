---
import Base from '../../layouts/Base.astro';
import EducatorCard from '../../components/EducatorCard.astro';
import { team } from '../../data/team';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title="Our Team — Koala Kids Early Learning" description="Eight educators, all diploma- or degree-qualified, with an average of nine years in early childhood education.">
  <section class="pt-16 pb-10">
    <div class="wrap max-w-3xl">
      <p class="eyebrow">Our team</p>
      <h1 class="text-5xl md:text-6xl leading-[1.02] mb-6">The people in the building.</h1>
      <p class="text-earth/80 text-lg leading-relaxed">
        Eight educators. Every one of us is diploma- or degree-qualified. Our average tenure at Koala Kids is four years, and our average experience in the sector is nine.
      </p>
    </div>
  </section>

  <section class="py-12">
    <div class="wrap">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {team.map(e => <EducatorCard educator={e} />)}
      </div>
    </div>
  </section>

  <section class="py-20 bg-sandstone/50">
    <div class="wrap grid md:grid-cols-3 gap-10 items-start">
      <div class="md:col-span-1">
        <p class="eyebrow">Continuing education</p>
        <h2 class="text-3xl md:text-4xl">We invest in our team.</h2>
      </div>
      <div class="md:col-span-2">
        <p class="text-earth/85 text-lg leading-relaxed mb-5">Every educator is given four paid professional development days per year, plus a $1,200 annual learning budget that they choose how to spend. We\'ve sent staff to Reggio Emilia study tours in Italy, funded postgraduate coursework in infant mental health, and hosted monthly in-house research circles.</p>
        <p class="text-earth/85 text-lg leading-relaxed">We don\'t do casual pools. If someone is sick, another room lead covers. Continuity of relationships matters more to young children than almost anything else we do.</p>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="wrap text-center max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl mb-5">Come meet them.</h2>
      <p class="text-earth/80 text-lg mb-8">All tours are hosted by Harriet or Liam. You\'ll meet at least three other educators during a forty-minute visit.</p>
      <a href={`${base}/tours/`} class="btn-primary">Book a tour</a>
    </div>
  </section>
</Base>
