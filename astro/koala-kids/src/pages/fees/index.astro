---
import Base from '../../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const inclusions = [
  'All three meals plus morning and afternoon tea, cooked fresh daily',
  'All nappies, wipes, bedding, sunscreen and insect repellent',
  'All excursions, including bush kinder and preschool excursions',
  'Incursions: music, yoga, visiting artists, cultural educators',
  'Specialist-led programs (Indigenous perspectives, sustainability)',
  'Parent portal, learning stories, and biannual conferences',
];
const notIncluded = [
  'A change of clothes (please supply two spares daily)',
  'A wide-brim sun hat (we can supply if needed)',
  'A water bottle labelled with your child\'s name',
];

const ccsExamples = [
  { label: 'Family A · 95% CCS', income: 'Under $80,000 combined', daily: '$6.75', note: 'Before Additional Child Subsidy.' },
  { label: 'Family B · 60% CCS', income: '$150,000 combined', daily: '$54.00', note: 'Typical for dual-income professionals.' },
  { label: 'Family C · 20% CCS', income: 'Over $350,000 combined', daily: '$108.00', note: 'Minimum subsidy applies.' },
];

const faq = [
  { q: 'Are you CCS approved?', a: 'Yes. Koala Kids holds a full Service Approval through the Department of Education and is registered for the Child Care Subsidy. We\'ll help you complete your CCS application during enrolment.' },
  { q: 'Do you require a bond or holding fee?', a: 'A $250 refundable bond is payable on enrolment, fully refunded on your child\'s last day (or forfeited if notice periods are not met). No other upfront fees.' },
  { q: 'What\'s the notice period?', a: 'Two weeks\' written notice for any permanent schedule change or withdrawal.' },
  { q: 'Do I pay for public holidays?', a: 'Yes. Fees apply for all booked days, including public holidays. This is standard under the CCS framework.' },
  { q: 'Do you offer any fee relief?', a: 'We hold two Additional Child Care Subsidy places for families experiencing temporary financial hardship. Speak with Harriet in confidence.' },
];
---
<Base title="Fees & CCS — Koala Kids Early Learning" description="Daily fee $135 before subsidy. CCS approved. All meals, nappies and excursions included — no hidden extras.">
  <section class="pt-16 pb-10">
    <div class="wrap max-w-3xl">
      <p class="eyebrow">Fees &amp; subsidies</p>
      <h1 class="text-5xl md:text-6xl leading-[1.02] mb-6">$135 a day. Nothing hidden.</h1>
      <p class="text-earth/80 text-lg leading-relaxed">
        Our daily fee is the same across all five rooms. All meals, nappies and excursions are included. Most families pay significantly less after the Child Care Subsidy — here\'s how it breaks down.
      </p>
    </div>
  </section>

  {/* CCS walkthrough */}
  <section class="py-12">
    <div class="wrap">
      <div class="grid md:grid-cols-3 gap-6 mb-12">
        {ccsExamples.map(c => (
          <article class="card">
            <div class="font-mono uppercase text-[10px] tracking-soft text-terracotta mb-3">{c.label}</div>
            <div class="font-display text-3xl text-softcoal mb-1">{c.daily}</div>
            <div class="font-mono text-[11px] uppercase tracking-soft text-earth/60 mb-4">per day, out of pocket</div>
            <p class="text-earth/75 text-sm leading-relaxed mb-2">Household income: {c.income}</p>
            <p class="text-earth/60 text-xs italic">{c.note}</p>
          </article>
        ))}
      </div>
      <p class="text-earth/70 text-sm max-w-3xl">Examples based on a child attending 2 days per week. Subsidies vary based on activity test, income, and number of children in care. Use the <a href="https://www.servicesaustralia.gov.au/child-care-subsidy" class="text-eucalypt underline">Services Australia estimator</a> or ask Harriet to walk you through your specific scenario.</p>
    </div>
  </section>

  {/* Inclusions */}
  <section class="py-20 bg-sandstone/50">
    <div class="wrap grid md:grid-cols-2 gap-14">
      <div>
        <p class="eyebrow">Included</p>
        <h2 class="text-3xl md:text-4xl mb-6">What your daily fee covers.</h2>
        <ul class="space-y-4">
          {inclusions.map(i => (
            <li class="flex gap-3 text-earth/85">
              <span class="text-eucalypt mt-[2px] shrink-0">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 10l4 4 8-9"/></svg>
              </span>
              <span>{i}</span>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <p class="font-mono uppercase text-[10px] tracking-soft text-terracotta mb-4">// What to bring</p>
        <h2 class="text-3xl md:text-4xl mb-6">You pack these.</h2>
        <ul class="space-y-4">
          {notIncluded.map(i => (
            <li class="flex gap-3 text-earth/85">
              <span class="text-terracotta mt-[2px] shrink-0">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 10h8"/></svg>
              </span>
              <span>{i}</span>
            </li>
          ))}
        </ul>
        <p class="text-earth/60 text-sm mt-6 italic">That\'s the full list. We supply everything else.</p>
      </div>
    </div>
  </section>

  {/* FAQ */}
  <section id="faq" class="py-20">
    <div class="wrap max-w-3xl">
      <p class="eyebrow">Fee FAQ</p>
      <h2 class="text-3xl md:text-4xl mb-10">Things parents ask us.</h2>
      <dl class="space-y-6">
        {faq.map(f => (
          <div class="card">
            <dt class="font-display text-xl text-softcoal mb-3">{f.q}</dt>
            <dd class="text-earth/80 leading-relaxed">{f.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section class="py-20 bg-eucalypt text-cream">
    <div class="wrap text-center max-w-2xl mx-auto">
      <h2 class="text-cream text-3xl md:text-4xl mb-5">Ready to enrol?</h2>
      <p class="text-cream/85 text-lg mb-8">We have limited availability — book a tour, and we\'ll walk you through exact costs for your family during the visit.</p>
      <a href={`${base}/tours/`} class="btn-accent">Book your tour</a>
    </div>
  </section>
</Base>
