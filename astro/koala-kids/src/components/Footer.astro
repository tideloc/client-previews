---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();
---
<footer class="mt-24 bg-softcoal text-cream/90">
  <div class="wrap py-12 border-b border-cream/10">
    <div class="max-w-3xl">
      <p class="font-mono uppercase text-[10px] tracking-soft text-pollen mb-3">// Acknowledgement of Country</p>
      <p class="text-cream/85 text-sm md:text-base leading-relaxed font-display">
        Koala Kids Early Learning acknowledges the Awabakal and Worimi peoples as the Traditional Custodians of the land on which we learn and play. We pay our respects to Elders past and present, and thank the children — our youngest teachers — for the curiosity that keeps us connected to Country.
      </p>
    </div>
  </div>
  <div class="wrap py-14 grid md:grid-cols-4 gap-10">
    <div>
      <div class="flex items-center gap-3 mb-4">
        <span class="w-11 h-11 bg-eucalypt text-cream flex items-center justify-center font-display text-lg rounded-card">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3c3 2 5 5 5 9a5 5 0 0 1-10 0c0-4 2-7 5-9Z"/>
            <path d="M12 12v9"/>
          </svg>
        </span>
        <div class="font-display text-cream text-base">Koala Kids</div>
      </div>
      <p class="text-cream/70 text-sm leading-relaxed">A small boutique early learning centre on the edge of Newcastle West. Outdoor-led days, qualified educators, a kitchen that cooks everything from scratch.</p>
    </div>
    <div>
      <h4 class="text-cream text-xs uppercase font-mono tracking-soft mb-4">Explore</h4>
      <ul class="space-y-2 text-sm">
        <li><a href={`${base}/rooms/`} class="text-cream/70 hover:text-pollen">Our rooms</a></li>
        <li><a href={`${base}/approach/`} class="text-cream/70 hover:text-pollen">Our approach</a></li>
        <li><a href={`${base}/team/`} class="text-cream/70 hover:text-pollen">Our educators</a></li>
        <li><a href={`${base}/fees/`} class="text-cream/70 hover:text-pollen">Fees &amp; CCS</a></li>
      </ul>
    </div>
    <div>
      <h4 class="text-cream text-xs uppercase font-mono tracking-soft mb-4">Visit</h4>
      <ul class="space-y-2 text-sm">
        <li><a href={`${base}/tours/`} class="text-cream/70 hover:text-pollen">Book a tour</a></li>
        <li><a href={`${base}/contact/`} class="text-cream/70 hover:text-pollen">Contact us</a></li>
        <li><a href={`${base}/approach/#menu`} class="text-cream/70 hover:text-pollen">Weekly menu</a></li>
        <li><a href={`${base}/fees/#faq`} class="text-cream/70 hover:text-pollen">Fee FAQ</a></li>
      </ul>
    </div>
    <div>
      <h4 class="text-cream text-xs uppercase font-mono tracking-soft mb-4">Find us</h4>
      <address class="not-italic text-sm text-cream/70 leading-relaxed">
        Koala Kids Early Learning<br/>
        37 Parry Street<br/>
        Newcastle West NSW 2302<br/>
        <a href="tel:0249291010" class="text-pollen hover:text-cream">(02) 4929 1010</a><br/>
        <a href="mailto:hello@koalakids.com.au" class="text-pollen hover:text-cream">hello@koalakids.com.au</a>
      </address>
    </div>
  </div>
  <div class="border-t border-cream/10">
    <div class="wrap py-6 flex flex-col md:flex-row items-center justify-between gap-2 text-xs text-cream/55">
      <span>© {year} Koala Kids Early Learning Pty Ltd. Service Approval NSW. ABN 00 000 000 000.</span>
      <span class="font-mono uppercase tracking-soft">Open 7:00am – 6:00pm · Mon to Fri</span>
    </div>
  </div>
</footer>
