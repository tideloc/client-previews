---
import type { Cooperative } from '../data/cooperatives';
interface Props { coop: Cooperative }
const { coop } = Astro.props;
---
<article class="paper-card overflow-hidden">
  <div class="relative aspect-[16/10] overflow-hidden">
    <img src={coop.image} alt={coop.name} class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-charcoal/60 to-transparent"></div>
    <div class="absolute bottom-3 left-4 right-4 flex items-end justify-between gap-4">
      <div>
        <div class="font-mono text-[10px] uppercase tracking-wide2 text-chalk/90">Cooperative</div>
        <div class="font-display text-2xl text-chalk leading-tight">{coop.name}</div>
      </div>
      <div class="text-right">
        <div class="font-mono text-[10px] uppercase tracking-wide2 text-chalk/70">Country</div>
        <div class="font-mono text-xs text-chalk">{coop.country}</div>
      </div>
    </div>
  </div>
  <div class="p-6">
    <div class="flex items-baseline justify-between mb-3">
      <span class="field-label">{coop.region}</span>
      <span class="coord">{coop.coords[0].toFixed(3)}° / {coop.coords[1].toFixed(3)}°</span>
    </div>
    <p class="text-charcoal/75 text-[14px] leading-relaxed">{coop.description}</p>
  </div>
</article>
