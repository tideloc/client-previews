---
import type { Product } from '../data/products';
interface Props { product: Product; compact?: boolean }
const { product, compact = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const catLabel: Record<string, string> = {
  spice: 'Native Spice',
  fruit: 'Bush Fruit',
  seed: 'Seed / Grain',
  protein: 'Native Protein',
  sauce: 'Sauce / Condiment',
  hamper: 'Gift Hamper',
};
---
<a href={`${base}/pantry/${product.slug}/`} class="group block paper-card hover:border-ochre/40 transition">
  <div class="relative aspect-[4/5] overflow-hidden bg-sand/30">
    <img
      src={product.image}
      alt={product.name}
      class="w-full h-full object-cover group-hover:scale-[1.04] transition duration-700"
     
    />
    {product.badge && (
      <span class="absolute top-3 left-3 bg-charcoal text-chalk px-2 py-1 font-mono uppercase tracking-wide2 text-[10px]">{product.badge}</span>
    )}
    <span class="absolute top-3 right-3 font-mono text-[10px] uppercase tracking-wide2 text-chalk bg-kangaroo/70 px-2 py-1">{product.size}</span>
  </div>
  <div class={`p-5 ${compact ? 'pb-4' : ''}`}>
    <div class="field-label mb-1">{catLabel[product.category]}</div>
    <div class="flex items-baseline justify-between gap-3">
      <h3 class="text-xl text-charcoal leading-tight group-hover:text-ochre transition">{product.name}</h3>
      <span class="font-mono text-sm text-ochre whitespace-nowrap">${product.price}</span>
    </div>
    {!compact && (
      <p class="font-display italic text-kangaroo/80 text-[13px] mt-0.5 mb-3">{product.botanicalName}</p>
      <p class="text-charcoal/70 text-[14px] leading-relaxed">{product.blurb}</p>
    )}
    {compact && (
      <p class="font-display italic text-kangaroo/80 text-[12px] mt-0.5">{product.botanicalName}</p>
    )}
  </div>
</a>
