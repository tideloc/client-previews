---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const links = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/pantry/`, label: 'Pantry' },
  { href: `${base}/stories/`, label: 'Stories' },
  { href: `${base}/harvest/`, label: 'Harvest' },
  { href: `${base}/recipes/`, label: 'Recipes' },
  { href: `${base}/about/`, label: 'About' },
];
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="sticky top-0 z-40 bg-chalk/92 backdrop-blur-md border-b border-charcoal/10">
  <div class="wrap flex items-center justify-between py-4">
    <a href={`${base}/`} class="flex items-center gap-3 group">
      <span class="relative w-11 h-11 border border-charcoal/30 flex items-center justify-center rounded-full bg-chalk transition group-hover:border-ochre">
        <span class="font-display text-[22px] leading-none text-ochre">O</span>
        <span class="absolute -right-1 -top-1 w-2 h-2 rounded-full bg-ochre"></span>
      </span>
      <div class="leading-tight">
        <div class="font-display text-lg text-charcoal">Outback Pantry</div>
        <div class="font-mono text-[10px] text-kangaroo uppercase tracking-wide2">Alice Springs · Est. 2017</div>
      </div>
    </a>
    <nav class="hidden md:flex items-center gap-1">
      {links.map(l => {
        const isActive = pathname === l.href.replace(/\/$/, '') || (l.href === `${base}/` && pathname === base);
        return (
          <a
            href={l.href}
            class={`font-body font-medium text-[13px] px-3 py-2 transition hover:text-ochre ${isActive ? 'text-ochre' : 'text-charcoal/80'}`}
          >
            {l.label}
          </a>
        );
      })}
      <a href={`${base}/pantry/`} class="btn-primary ml-3 !py-2 !px-4 !text-xs">Cart · 0</a>
    </nav>
    <button id="menuToggle" class="md:hidden text-charcoal p-2" aria-label="Menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="4" y1="7" x2="20" y2="7" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="17" x2="20" y2="17" />
      </svg>
    </button>
  </div>
  <div id="mobileMenu" class="hidden md:hidden border-t border-charcoal/10 bg-chalk">
    <div class="wrap py-4 flex flex-col gap-1">
      {links.map(l => (
        <a href={l.href} class="font-body text-sm text-charcoal py-2 hover:text-ochre">{l.label}</a>
      ))}
      <a href={`${base}/pantry/`} class="btn-primary mt-3 !text-xs">Cart · 0</a>
    </div>
  </div>
</header>
<script>
  const btn = document.getElementById('menuToggle');
  const menu = document.getElementById('mobileMenu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
