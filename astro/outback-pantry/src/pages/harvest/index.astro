---
import Base from '../../layouts/Base.astro';
import CooperativeCard from '../../components/CooperativeCard.astro';
import { cooperatives } from '../../data/cooperatives';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const heroImg = 'https://images.unsplash.com/photo-1523626752472-b55a628f1acc?w=2000&h=1100&fit=crop&q=80&auto=format';
const mapImg = 'https://images.unsplash.com/photo-1584473457406-6240486418e9?w=2000&h=1400&fit=crop&q=80&auto=format';
---
<Base title="Harvest Network — Outback Pantry" description="The five Indigenous-led cooperatives we source from, with published payment terms and partnership length.">
  {/* Hero */}
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img src={heroImg} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-b from-charcoal/80 to-charcoal/40"></div>
    </div>
    <div class="wrap relative py-24 md:py-36">
      <p class="font-mono uppercase tracking-wide2 text-ochre text-[11px] mb-5">// Supply chain — transparent by default</p>
      <h1 class="text-5xl md:text-8xl text-chalk font-display leading-none">The harvest<br/><span class="text-ochre italic">network.</span></h1>
      <p class="text-chalk/85 text-lg md:text-xl max-w-2xl mt-8 leading-relaxed">
        Five Indigenous-led cooperatives. Thirty-eight harvesters. One published pay schedule. Here is everyone we work with and what we pay them.
      </p>
    </div>
  </section>

  {/* Map with overlays */}
  <section class="py-20">
    <div class="wrap">
      <div class="fg-divider mb-6">
        <span class="font-mono text-[10px] uppercase tracking-wide2 text-ochre">Map · 113°E – 154°E</span>
      </div>
      <h2 class="text-3xl md:text-5xl text-charcoal leading-tight mb-12 max-w-3xl">Five cooperatives, four states, one published pay schedule.</h2>

      <div class="relative paper-card overflow-hidden">
        <img src={mapImg} alt="Central Australian landscape" class="w-full aspect-[16/10] object-cover" />
        <svg viewBox="0 0 1200 750" class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true">
          {cooperatives.map((c, i) => {
            const lngMin = 113, lngMax = 154, latMin = -44, latMax = -10;
            const x = ((c.coords[1] - lngMin) / (lngMax - lngMin)) * 1200;
            const y = 750 - ((c.coords[0] - latMin) / (latMax - latMin)) * 750;
            return (
              <g>
                <circle cx={x} cy={y} r="16" fill="#b4571f" fill-opacity="0.25" />
                <circle cx={x} cy={y} r="7" fill="#b4571f" />
                <text x={x + 18} y={y + 5} fill="#f5ede0" font-family="JetBrains Mono, monospace" font-size="16" font-weight="500" style="text-shadow: 0 1px 3px rgba(0,0,0,0.9);">
                  0{i + 1} · {c.name}
                </text>
              </g>
            );
          })}
        </svg>
        <div class="absolute bottom-3 left-3 right-3 flex items-center justify-between text-chalk bg-charcoal/80 px-3 py-2 font-mono text-[10px] uppercase tracking-wide2">
          <span>Central Australia · harvest network</span>
          <span class="text-ochre">All pins current to April 2026</span>
        </div>
      </div>
    </div>
  </section>

  {/* Transparency on payments */}
  <section class="py-20 bg-sand/50 border-y border-charcoal/10">
    <div class="wrap grid md:grid-cols-12 gap-10">
      <div class="md:col-span-5">
        <p class="eyebrow">How we pay</p>
        <h2 class="text-3xl md:text-4xl text-charcoal leading-tight mb-6">A published rate, a floor, and a crop-failure buffer.</h2>
        <p class="text-charcoal/80 leading-relaxed">
          Our payments to each cooperative sit 30–40% above what a spot buyer in the same season would offer. We sign three-year fixed-rate contracts, pay a minimum floor volume regardless of demand, and carry a one-year crop-failure buffer so that the harvesters can plan their year.
        </p>
      </div>
      <div class="md:col-span-7">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b-2 border-charcoal/20">
              <th class="py-3 font-mono uppercase tracking-wide2 text-[11px] text-kangaroo">Cooperative</th>
              <th class="py-3 font-mono uppercase tracking-wide2 text-[11px] text-kangaroo">Yrs with us</th>
              <th class="py-3 font-mono uppercase tracking-wide2 text-[11px] text-kangaroo">Model</th>
            </tr>
          </thead>
          <tbody>
            {cooperatives.map((c) => (
              <tr class="border-b border-charcoal/10">
                <td class="py-4 pr-3 align-top">
                  <div class="font-display text-lg text-charcoal leading-tight">{c.name}</div>
                  <div class="font-mono text-[11px] text-kangaroo/80 mt-0.5">{c.country}</div>
                </td>
                <td class="py-4 pr-3 align-top">
                  <div class="font-display text-2xl text-ochre">{c.yearsPartnered}</div>
                </td>
                <td class="py-4 text-charcoal/80 text-sm leading-relaxed align-top">{c.paymentModel}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  {/* Cooperatives list */}
  <section class="py-20">
    <div class="wrap">
      <div class="flex items-end justify-between flex-wrap gap-4 mb-12">
        <div>
          <p class="eyebrow">Our partners</p>
          <h2 class="text-3xl md:text-5xl text-charcoal leading-tight">The five cooperatives.</h2>
        </div>
        <div class="coord">Updated Apr 2026</div>
      </div>

      <div class="space-y-16">
        {cooperatives.map((c, i) => (
          <article id={c.slug} class="scroll-mt-28 grid md:grid-cols-12 gap-10 items-start">
            <div class="md:col-span-5">
              <CooperativeCard coop={c} />
            </div>
            <div class="md:col-span-7">
              <div class="fg-divider mb-4">
                <span class="font-mono text-[10px] uppercase tracking-wide2">Co-op 0{i + 1}</span>
              </div>
              <h3 class="text-3xl md:text-4xl text-charcoal mb-3">{c.name}</h3>
              <div class="flex flex-wrap gap-x-6 gap-y-2 mb-6 text-sm">
                <div><span class="field-label mr-2">Country</span><span class="text-charcoal">{c.country}</span></div>
                <div><span class="field-label mr-2">Region</span><span class="text-charcoal">{c.region}</span></div>
                <div><span class="field-label mr-2">Coords</span><span class="coord">{c.coords[0].toFixed(3)}° / {c.coords[1].toFixed(3)}°</span></div>
              </div>
              <p class="text-charcoal/85 leading-relaxed mb-6 text-[16px]">{c.description}</p>
              <dl class="grid sm:grid-cols-3 gap-6 pt-6 border-t border-charcoal/10">
                <div>
                  <dt class="field-label mb-1">Supplies</dt>
                  <dd class="text-charcoal/80 text-sm leading-relaxed">{c.supplies.join(', ')}</dd>
                </div>
                <div>
                  <dt class="field-label mb-1">Partnered</dt>
                  <dd class="font-display text-2xl text-ochre">{c.yearsPartnered} years</dd>
                </div>
                <div>
                  <dt class="field-label mb-1">Payment model</dt>
                  <dd class="text-charcoal/80 text-sm leading-relaxed">{c.paymentModel}</dd>
                </div>
              </dl>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* How partnerships work */}
  <section class="py-20 bg-ironbark text-chalk">
    <div class="wrap grid md:grid-cols-12 gap-10">
      <div class="md:col-span-5">
        <p class="font-mono uppercase tracking-wide2 text-ochre text-[11px] mb-4">// Our process</p>
        <h2 class="text-3xl md:text-5xl leading-tight">How a partnership gets started.</h2>
      </div>
      <ol class="md:col-span-7 space-y-8">
        {[
          { step: '01', name: 'Introduction, on Country', body: 'All first meetings happen on the cooperative\'s Country, never in Alice or on Zoom. Aunty Linda attends every introduction.' },
          { step: '02', name: 'Protocol agreement', body: 'The cooperative sets the harvest protocol, the volume cap, and the off-limits sites. We sign it before we talk price.' },
          { step: '03', name: 'Published floor price', body: 'A three-year fixed per-kilo rate is agreed, published on this page, and indexed to AWE annually.' },
          { step: '04', name: 'Yearly review', body: 'Every December we return, sit down with the cooperative, and review what worked. We have walked away from two partnerships because the review showed we should.' },
        ].map((s) => (
          <li class="grid grid-cols-[60px_1fr] gap-4">
            <span class="font-display text-4xl text-ochre leading-none">{s.step}</span>
            <div>
              <h4 class="text-xl text-chalk mb-1">{s.name}</h4>
              <p class="text-chalk/75 leading-relaxed">{s.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="py-20">
    <div class="wrap max-w-2xl text-center">
      <p class="eyebrow">Partnership enquiries</p>
      <h2 class="text-3xl md:text-4xl text-charcoal mb-4">Are you a harvest cooperative?</h2>
      <p class="text-charcoal/75 leading-relaxed mb-8">
        We expand our partnerships by one or two cooperatives every two years. Introductions are best made through existing contacts in the native-foods industry, or through your local Indigenous Business Australia office.
      </p>
      <a href="mailto:partnerships@outbackpantry.com.au" class="btn-primary">partnerships@outbackpantry.com.au</a>
    </div>
  </section>
</Base>
