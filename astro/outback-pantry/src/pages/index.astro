---
import Base from '../layouts/Base.astro';
import Ticker from '../components/Ticker.astro';
import ProductCard from '../components/ProductCard.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { products } from '../data/products';
import { recipes } from '../data/recipes';
import { cooperatives } from '../data/cooperatives';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// "Essential Six" — the hero pantry
const essentialSix = [
  'mountain-pepperberry',
  'wattleseed-roast',
  'lemon-myrtle-leaf',
  'kakadu-plum-powder',
  'wattleseed-dukkah',
  'saltbush-salt',
].map((s) => products.find((p) => p.slug === s)!).filter(Boolean);

const featuredRecipe = recipes.find((r) => r.slug === 'wattleseed-damper-saltbush-butter')!;

// Harvest calendar — this month / in season
const inSeason = [
  { name: 'Kakadu plum', region: 'Top End · Kimberley', country: 'Yawuru / Nyul Nyul' },
  { name: 'Desert lime', region: 'Mallee · NSW', country: 'Ngiyampaa' },
  { name: 'Bunya nut', region: 'Bunya Mountains · QLD', country: 'Wakka Wakka' },
  { name: 'Quandong', region: 'Flinders Ranges · SA', country: 'Adnyamathanha' },
  { name: 'Lemon myrtle', region: 'Northern rivers · NSW', country: 'Bundjalung' },
  { name: 'Macadamia', region: 'Tweed Valley · NSW', country: 'Bundjalung' },
];

const heroImg = 'https://images.unsplash.com/photo-1523626752472-b55a628f1acc?w=2400&h=1400&fit=crop&q=80&auto=format';
const countryImg = 'https://images.unsplash.com/photo-1584473457406-6240486418e9?w=1600&h=1000&fit=crop&q=80&auto=format';
const recipeImg = featuredRecipe.image;
const trader = 'https://images.unsplash.com/photo-1488459716781-31db52582fe9?w=1800&h=1000&fit=crop&q=80&auto=format';
---
<Base title="Outback Pantry — Native Australian Foods, Harvested on Country">
  {/* ————————————————————————————————————————————————— HERO */}
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img src={heroImg} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-br from-charcoal/75 via-charcoal/45 to-charcoal/60"></div>
    </div>
    <div class="wrap relative py-24 md:py-36">
      <div class="max-w-3xl">
        <p class="font-mono uppercase tracking-wide2 text-[11px] text-chalk/80 mb-6">
          <span class="text-ochre">// </span>Field guide vol. 07 · Alice Springs, Australia
        </p>
        <h1 class="font-display text-chalk leading-[0.95] mb-6">
          <span class="block text-[clamp(2.8rem,10vw,7.5rem)]">Tastes of country.</span>
          <span class="block text-[clamp(2.8rem,10vw,7.5rem)] text-ochre italic">Harvested with care.</span>
        </h1>
        <p class="text-chalk/85 text-lg md:text-xl leading-relaxed mb-10 max-w-2xl">
          Native Australian spices, bush fruits, seeds and staples — sourced from twelve Indigenous-led cooperatives across the Territory, the Kimberley and the central desert. Every jar traces back to the Country it grew on, and the people who picked it.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href={`${base}/pantry/`} class="btn-primary">Shop the pantry</a>
          <a href={`${base}/stories/`} class="inline-flex items-center gap-2 border border-chalk/40 text-chalk px-6 py-3 text-sm font-medium hover:bg-chalk hover:text-charcoal transition">Learn the stories</a>
        </div>

        {/* Field-note card */}
        <aside class="mt-16 grid grid-cols-3 md:grid-cols-3 gap-4 max-w-2xl">
          <div class="border-l border-chalk/20 pl-4">
            <div class="coord text-chalk/70">-23.698°</div>
            <div class="coord text-chalk/70">133.881°</div>
            <div class="text-chalk/90 text-sm mt-2">Mparntwe</div>
          </div>
          <div class="border-l border-chalk/20 pl-4">
            <div class="text-chalk/60 font-mono text-[10px] uppercase tracking-wide2">Partners</div>
            <div class="font-display text-3xl text-chalk">05</div>
            <div class="text-chalk/90 text-sm mt-1">Cooperatives on Country</div>
          </div>
          <div class="border-l border-chalk/20 pl-4">
            <div class="text-chalk/60 font-mono text-[10px] uppercase tracking-wide2">Catalogue</div>
            <div class="font-display text-3xl text-chalk">{products.length}</div>
            <div class="text-chalk/90 text-sm mt-1">Small-batch products</div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <Ticker items={['Wattleseed · dark roast', 'Mountain pepperberry', 'Kakadu plum powder', 'Desert lime', 'Bunya nut', 'Saltbush salt', 'Lemon myrtle leaf', 'Quandong chutney']} />

  {/* ————————————————————————————————————————————————— IN SEASON */}
  <section class="py-24">
    <div class="wrap">
      <div class="flex items-end justify-between flex-wrap gap-6 mb-14">
        <div>
          <p class="eyebrow">In season this month</p>
          <h2 class="text-4xl md:text-5xl text-charcoal leading-tight">What Country is giving<br/>right now.</h2>
          <div class="rule mt-6"></div>
        </div>
        <div class="text-right">
          <div class="coord">Apr 2026</div>
          <div class="font-mono text-xs text-kangaroo/80 mt-1">// Autumn · Central Australia</div>
        </div>
      </div>

      <ul class="grid md:grid-cols-3 gap-6">
        {inSeason.map((item, i) => (
          <li class="paper-card p-6 flex gap-4 items-start">
            <div class="font-mono text-[12px] text-ochre mt-1">0{i + 1}</div>
            <div>
              <div class="font-display text-xl text-charcoal mb-1">{item.name}</div>
              <div class="field-label mb-1">{item.country}</div>
              <div class="text-charcoal/70 text-[14px]">{item.region}</div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* ————————————————————————————————————————————————— FEATURED COLLECTION */}
  <section class="py-24 bg-sand/40 border-y border-charcoal/10">
    <div class="wrap">
      <div class="flex items-end justify-between flex-wrap gap-6 mb-14">
        <div>
          <p class="eyebrow">The essential six</p>
          <h2 class="text-4xl md:text-5xl text-charcoal leading-tight">Start with<br/>these six jars.</h2>
          <p class="text-charcoal/70 max-w-xl mt-5 leading-relaxed">A pantry that covers about 80% of native-ingredient cooking. Buy them individually, or grab them as a hamper and skip the shipping on five of them.</p>
        </div>
        <a href={`${base}/pantry/`} class="font-mono uppercase tracking-wide2 text-[12px] text-ochre hover:text-bloodwood">See full catalogue →</a>
      </div>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
        {essentialSix.map((p) => <ProductCard product={p} />)}
      </div>
    </div>
  </section>

  {/* ————————————————————————————————————————————————— COUNTRY + MAP */}
  <section class="py-24">
    <div class="wrap grid md:grid-cols-12 gap-12 items-start">
      <div class="md:col-span-5">
        <p class="eyebrow">Acknowledgment of Country</p>
        <h2 class="text-4xl md:text-5xl text-charcoal leading-tight mb-8">The food on this shelf has been cared for for 60,000 years.</h2>
        <div class="space-y-5 text-charcoal/80 leading-relaxed">
          <p>
            Outback Pantry is based in Mparntwe, on the unceded lands of the Arrernte people. We work with five Indigenous-led cooperatives across the Northern Territory, the Kimberley, Tasmania and Western NSW.
          </p>
          <p>
            The knowledge that tells us a wattleseed is ready in August, that a quandong needs three seasons of rain to fruit, that a pepperberry can be split but never pounded — all of it was carried here by First Nations people across thousands of generations.
          </p>
          <p>
            Outback Pantry is a settler-founded grocer. We are not Indigenous-owned, and we try not to pretend to be. What we <em class="text-ochre not-italic font-medium">can</em> do is publish our payment rates, work on three-year contracts, and give you a product that lets you honour the Country it came from.
          </p>
        </div>
        <a href={`${base}/harvest/`} class="btn-ghost mt-8">See the harvest network</a>
      </div>
      <div class="md:col-span-7">
        <div class="relative paper-card overflow-hidden">
          <img src={countryImg} alt="Central Australian desert landscape" class="w-full aspect-[5/4] object-cover" />
          {/* Cartographic overlay with pin markers */}
          <svg viewBox="0 0 800 640" class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true">
            {cooperatives.map((c, i) => {
              // rough geographic positioning on a normalised rectangle representing Australia
              const lngMin = 113, lngMax = 154, latMin = -44, latMax = -10;
              const x = ((c.coords[1] - lngMin) / (lngMax - lngMin)) * 800;
              const y = 640 - ((c.coords[0] - latMin) / (latMax - latMin)) * 640;
              return (
                <g>
                  <circle cx={x} cy={y} r="9" fill="#b4571f" fill-opacity="0.25" />
                  <circle cx={x} cy={y} r="4" fill="#b4571f" />
                  <text x={x + 12} y={y + 4} fill="#f5ede0" font-family="JetBrains Mono, monospace" font-size="12" style="text-shadow: 0 1px 2px rgba(0,0,0,0.8);">0{i + 1}</text>
                </g>
              );
            })}
          </svg>
          <div class="absolute bottom-3 left-3 right-3 font-mono text-[10px] uppercase tracking-wide2 text-chalk bg-charcoal/80 px-3 py-2 flex items-center justify-between">
            <span>Harvest network · 5 cooperatives</span>
            <span class="text-ochre">113°E – 154°E / 10°S – 44°S</span>
          </div>
        </div>
        <ol class="mt-6 grid grid-cols-2 gap-3 text-[13px]">
          {cooperatives.map((c, i) => (
            <li class="flex gap-2">
              <span class="font-mono text-ochre">0{i + 1}</span>
              <span class="text-charcoal/80">{c.name} · <span class="text-kangaroo/80">{c.country}</span></span>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  {/* ————————————————————————————————————————————————— RECIPE FEATURE */}
  <section class="py-24 bg-ironbark text-chalk relative overflow-hidden">
    <div class="absolute inset-0 opacity-25">
      <img src={recipeImg} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-ironbark via-ironbark/80 to-ironbark/40"></div>
    </div>
    <div class="wrap relative grid md:grid-cols-12 gap-12 items-center">
      <div class="md:col-span-6">
        <p class="font-mono uppercase tracking-wide2 text-ochre text-[11px] mb-4">// This week's recipe</p>
        <h2 class="text-4xl md:text-6xl leading-[1.05] mb-6">Wattleseed damper with saltbush butter.</h2>
        <p class="text-chalk/80 text-lg leading-relaxed mb-8 max-w-lg">
          A dark-crusted, mocha-scented damper with a cold slab of saltbush-flecked cultured butter. Traditional, quiet, and so much better than the version you had at school camp.
        </p>
        <div class="flex items-center gap-8 mb-8 font-mono uppercase tracking-wide2 text-[11px] text-chalk/70">
          <div>
            <div class="text-ochre">Time</div>
            <div class="text-chalk text-sm mt-1">{featuredRecipe.time}</div>
          </div>
          <div>
            <div class="text-ochre">Serves</div>
            <div class="text-chalk text-sm mt-1">{featuredRecipe.serves}</div>
          </div>
          <div>
            <div class="text-ochre">Difficulty</div>
            <div class="text-chalk text-sm mt-1">{featuredRecipe.difficulty}</div>
          </div>
        </div>
        <a href={`${base}/recipes/`} class="inline-flex items-center gap-2 border border-chalk/40 text-chalk px-6 py-3 text-sm font-medium hover:bg-chalk hover:text-charcoal transition">Read full recipe</a>
      </div>
      <div class="md:col-span-6">
        <div class="aspect-[4/5] overflow-hidden border border-chalk/15">
          <img src={featuredRecipe.image} alt={featuredRecipe.name} class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  {/* ————————————————————————————————————————————————— RECIPES STRIP */}
  <section class="py-24">
    <div class="wrap">
      <div class="flex items-end justify-between flex-wrap gap-6 mb-12">
        <div>
          <p class="eyebrow">More from the kitchen</p>
          <h2 class="text-4xl md:text-5xl text-charcoal">Cook like you mean it.</h2>
          <div class="rule mt-6"></div>
        </div>
        <a href={`${base}/recipes/`} class="font-mono uppercase tracking-wide2 text-[12px] text-ochre hover:text-bloodwood">All recipes →</a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {recipes.slice(1, 4).map((r) => <RecipeCard recipe={r} />)}
      </div>
    </div>
  </section>

  {/* ————————————————————————————————————————————————— HAMPER CTA */}
  <section class="py-24 bg-sand/50 border-y border-charcoal/10">
    <div class="wrap grid md:grid-cols-12 gap-10 items-center">
      <div class="md:col-span-7">
        <p class="eyebrow">Gift hampers</p>
        <h2 class="text-4xl md:text-5xl text-charcoal leading-tight mb-5">Six jars. One Hoop-pine crate. A very good gift.</h2>
        <p class="text-charcoal/75 text-lg leading-relaxed mb-6 max-w-xl">
          The hamper we send our own families — pepperberry, wattleseed, lemon myrtle, quandong chutney, saltbush salt and wattleseed dukkah. Packed in a locally-made crate with a recipe card and a handwritten note.
        </p>
        <a href={`${base}/pantry/essential-six-hamper/`} class="btn-primary">See the hamper — $129</a>
      </div>
      <div class="md:col-span-5">
        <div class="paper-card overflow-hidden">
          <img src={products.find((p) => p.slug === 'essential-six-hamper')!.image} alt="The Essential Six gift hamper" class="w-full aspect-[4/5] object-cover" />
        </div>
      </div>
    </div>
  </section>

  {/* ————————————————————————————————————————————————— TRADE BAND */}
  <section class="relative py-20 overflow-hidden bg-charcoal text-chalk">
    <div class="absolute inset-0 opacity-25">
      <img src={trader} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-b from-charcoal/90 to-charcoal/70"></div>
    </div>
    <div class="wrap relative grid md:grid-cols-12 gap-10 items-center">
      <div class="md:col-span-8">
        <p class="font-mono uppercase tracking-wide2 text-ochre text-[11px] mb-3">// Restaurants &amp; trade</p>
        <h2 class="text-3xl md:text-5xl text-chalk leading-tight mb-4">We supply 40+ kitchens from Mparntwe to Hobart.</h2>
        <p class="text-chalk/80 text-lg leading-relaxed max-w-2xl">
          Bulk 1kg and 5kg sizing, net-30 for established accounts, a dedicated chef-liaison who actually returns calls. Fully-documented origin for every ingredient, which your menu can print with pride.
        </p>
      </div>
      <div class="md:col-span-4 md:text-right">
        <a href={`${base}/about/#trade`} class="btn-primary">Open a trade account</a>
      </div>
    </div>
  </section>
</Base>
